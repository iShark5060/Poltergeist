import "../../../assets/Geist[wght].ttf";
import "../../../assets/GeistMono[wght].ttf";
import "../../../assets/Font Awesome 7 Free-Solid-900.otf";
import "../../../assets/Font Awesome 7 Free-Regular-400.otf";
import "../../../assets/Font Awesome 7 Brands-Regular-400.otf";

import {
    Button,
    LineEdit,
    ScrollView,
    CheckBox,
    VerticalBox,
    HorizontalBox,
    GridBox,
    ListView,
    StandardListView,
    Palette,
} from "std-widgets.slint";

export global Theme {
    in-out property <bool> is-light: false;

    out property <color> bg: root.is-light ? #f4f5f7 : #1e1f22;
    out property <color> bg-elev: root.is-light ? #ffffff : #2b2d31;
    out property <color> bg-input: root.is-light ? #f8f9fb : #1e1f22;
    out property <color> bg-input-focus: root.is-light ? #f8f9fb : #232428;
    out property <color> bg-hover: root.is-light ? #e9ebef : #35373c;
    out property <color> bg-active: root.is-light ? #dde0e6 : #404249;
    out property <color> border: root.is-light ? #d6d9de : #3a3c42;
    out property <color> border-strong: root.is-light ? #b8bcc4 : #4f545c;
    out property <color> border-focus: root.accent;
    out property <color> text: root.is-light ? #1d1f24 : #e3e5e8;
    out property <color> text-dim: root.is-light ? #4a4f57 : #b5bac1;
    out property <color> text-muted: root.is-light ? #6b7079 : #80848e;
    in-out property <color> accent: #5865f2;
    in-out property <color> accent-hover: #4752c4;
    in-out property <color> accent-soft: #3a3f8a;
    out property <color> danger: #ed4245;
    out property <color> success: #2ea043;
    out property <color> warning: root.is-light ? #b08800 : #fee75c;
    out property <color> selection: root.is-light ? #d8dcff : #404249;
    out property <color> selection-strong: root.is-light ? #c5cbff : #4e5058;
    out property <length> radius-sm: 4px;
    out property <length> radius-md: 6px;
    out property <length> radius-lg: 10px;
    out property <length> pad-sm: 6px;
    out property <length> pad-md: 10px;
    out property <length> pad-lg: 16px;
    out property <string> fa-family: "Font Awesome 7 Free";
    out property <string> fa-brands-family: "Font Awesome 7 Brands";
    out property <string> ui-font: "Geist";
    out property <string> ui-mono-font: "Geist Mono";
}

export struct ColorSwatchRow {
    label: string,
    hex: string,
    swatch: color,
}

export struct TreeRowData {
    label: string,
    icon-glyph: string,
    icon-color: color,
    icon-is-brands: bool,
    indent: int,
    is-folder: bool,
    is-folder-collapsed: bool,
    is-selected: bool,
    is-locked: bool,
    has-shortcut: bool,
    shortcut-text: string,
    node-color: color,
    has-node-color: bool,
}

export struct TokenChip {
    text: string,
    category: string,
}

export struct NodePickerRow {
    text: string,
    depth: int,
    is-folder: bool,
    has-children: bool,
    expanded: bool,
    color-hex: string,
    has-color: bool,
    check-state: int,
    inject-kbd: bool,
}

component FaGlyph inherits Text {
    in property <string> glyph;
    in property <bool> is-brands: false;
    in property <int> weight: 900;
    in property <length> glyph-size: 14px;
    in property <color> tint: Theme.text;
    horizontal-alignment: center;
    vertical-alignment: center;
    font-family: root.is-brands ? Theme.fa-brands-family : Theme.fa-family;
    font-weight: root.weight;
    font-size: root.glyph-size;
    color: root.tint;
    text: root.glyph;
}

component IconButton inherits Rectangle {
    in property <string> glyph;
    in property <bool> is-brands: false;
    in property <int> glyph-weight: 900;
    in property <string> tooltip-text;
    in property <bool> active: false;
    in property <bool> destructive: false;
    in property <bool> success: false;
    in property <bool> enabled: true;
    in property <length> btn-size: 36px;
    callback clicked();
    callback hover-changed(string);

    width: root.btn-size;
    height: root.btn-size;
    border-radius: Theme.radius-md;
    background: !root.enabled ? transparent
        : root.active ? Theme.bg-active
        : ta.pressed ? Theme.bg-active
        : ta.has-hover ? Theme.bg-hover
        : transparent;
    border-width: ta.has-hover && root.enabled ? 1px : 0;
    border-color: Theme.border;

    FaGlyph {
        glyph: root.glyph;
        is-brands: root.is-brands;
        weight: root.glyph-weight;
        glyph-size: root.btn-size * 0.45;
        tint: !root.enabled ? Theme.text-muted
            : root.destructive ? Theme.danger
            : root.success ? Theme.success
            : root.active ? Theme.text
            : ta.has-hover ? Theme.text
            : Theme.text-dim;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        changed has-hover => {
            root.hover-changed(self.has-hover ? root.tooltip-text : "");
        }
    }
}

component TabButton inherits Rectangle {
    in property <string> label;
    in property <string> icon-glyph;
    in property <string> trailing-glyph;
    in property <color> trailing-tint: Theme.text-muted;
    in property <bool> active: false;
    in property <bool> enabled: true;
    callback clicked();

    height: 34px;
    background: root.active ? Theme.bg-elev
        : ta.has-hover ? Theme.bg-hover
        : transparent;
    border-radius: Theme.radius-md;

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 8px;
        alignment: start;
        if root.icon-glyph != "" : FaGlyph {
            glyph: root.icon-glyph;
            glyph-size: 13px;
            tint: root.active ? Theme.text : Theme.text-dim;
            width: 16px;
            vertical-alignment: center;
        }
        Text {
            text: root.label;
            color: root.active ? Theme.text : Theme.text-dim;
            font-size: 13px;
            font-weight: root.active ? 600 : 500;
            vertical-alignment: center;
        }
        if root.trailing-glyph != "" : FaGlyph {
            glyph: root.trailing-glyph;
            glyph-size: 11px;
            tint: root.trailing-tint;
            width: 14px;
            vertical-alignment: center;
        }
    }

    if root.active : Rectangle {
        x: 0;
        y: parent.height - 2px;
        width: parent.width;
        height: 2px;
        background: Theme.accent;
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

component OptionsTabButton inherits Rectangle {
    in property <string> tab-label;
    in property <bool> tab-selected;
    callback tab-clicked;

    horizontal-stretch: 1;
    height: 36px;
    border-radius: Theme.radius-sm;
    background: tab-selected
        ? Theme.accent-soft
        : (tab-ta.has-hover ? Theme.bg-hover : transparent);

    VerticalLayout {
        padding-top: 6px;
        padding-bottom: 0;
        spacing: 0;
        Text {
            text: tab-label;
            color: tab-selected ? Theme.accent : Theme.text-dim;
            font-size: 14px;
            font-weight: tab-selected ? 700 : 500;
            horizontal-alignment: center;
            vertical-alignment: center;
            vertical-stretch: 1;
            overflow: elide;
        }
        Rectangle {
            height: 2px;
            background: tab-selected ? Theme.accent : transparent;
        }
    }

    tab-ta := TouchArea {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        clicked => {
            root.tab-clicked();
        }
    }
}

component FieldLabel inherits Text {
    in property <length> label-width: 92px;
    in property <bool> compact: false;
    color: Theme.text-dim;
    font-size: compact ? 13px : 16px;
    width: root.label-width;
    horizontal-alignment: right;
    vertical-alignment: center;
}

component OptionsFieldLabel inherits FieldLabel {
    label-width: 168px;
}

component TreeRow inherits Rectangle {
    in property <TreeRowData> row-data;
    in property <int> row-index;
    in property <bool> is-drop-above: false;
    in property <bool> is-drop-into: false;
    in property <bool> is-drop-source: false;
    private property <bool> rename-focus-arm: false;
    in property <bool> is-renaming: false;
    callback clicked();
    callback double-clicked();
    callback toggle-collapse(int);
    callback rename-submit(int, string);
    callback rename-cancel(int);
    callback drag-pressed(int, length);
    callback drag-moved(int, length);
    callback drag-released(int, length);

    height: 26px;
    border-radius: Theme.radius-sm;
    opacity: root.is-drop-source ? 0.45 : 1.0;
    background: row-data.is-selected ? Theme.selection-strong
        : root.is-drop-into ? Theme.accent-soft
        : ta.has-hover ? Theme.bg-hover
        : transparent;

    if root.is-drop-above : Rectangle {
        x: 0;
        y: -1px;
        width: parent.width;
        height: 2px;
        background: Theme.accent;
        border-radius: 1px;
    }

    HorizontalLayout {
        padding-left: max(4px, row-data.indent * 16px + 4px);
        padding-right: 6px;
        spacing: 4px;
        alignment: start;

        Rectangle {
            width: 14px;
            height: parent.height;
            if row-data.is-folder : Rectangle {
                width: parent.width;
                height: parent.height;
                FaGlyph {
                    glyph: row-data.is-folder-collapsed ? "\u{f054}" : "\u{f078}";
                    glyph-size: 9px;
                    tint: chevron-ta.has-hover ? Theme.text : Theme.text-dim;
                    weight: 900;
                    width: parent.width;
                    height: parent.height;
                }
                chevron-ta := TouchArea {
                    clicked => { root.toggle-collapse(root.row-index); }
                }
            }
        }

        Rectangle {
            width: 18px;
            height: parent.height;
            FaGlyph {
                glyph: row-data.icon-glyph;
                is-brands: row-data.icon-is-brands;
                glyph-size: 13px;
                tint: row-data.icon-color;
                width: parent.width;
                height: parent.height;
            }
        }
        if !root.is-renaming : Text {
            text: row-data.label;
            color: row-data.has-node-color ? row-data.node-color : Theme.text;
            font-size: 13px;
            font-weight: row-data.is-folder ? 600 : 400;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
        if root.is-renaming : Rectangle {
            background: Theme.is-light ? #ffffff : Theme.bg-input;
            border-width: 2px;
            border-color: Theme.accent;
            border-radius: Theme.radius-sm;
            horizontal-stretch: 1;
            height: parent.height - 2px;
            y: 1px;
            rename-input := TextInput {
                text: row-data.label;
                color: Theme.text;
                font-size: 13px;
                font-weight: row-data.is-folder ? 600 : 400;
                vertical-alignment: center;
                horizontal-alignment: left;
                single-line: true;
                wrap: no-wrap;
                selection-background-color: Theme.accent;
                selection-foreground-color: white;
                x: 6px;
                y: 0;
                width: parent.width - 12px;
                height: parent.height;
                accepted => { root.rename-submit(root.row-index, self.text); }
                key-pressed(event) => {
                    if (event.text == Key.Escape) {
                        root.rename-cancel(root.row-index);
                        return accept;
                    }
                    return reject;
                }
            }
            rename-focus-timer := Timer {
                interval: 1ms;
                running: root.rename-focus-arm;
                triggered => {
                    rename-input.focus();
                    rename-input.select-all();
                    root.rename-focus-arm = false;
                }
            }
        }
        if row-data.has-shortcut : Rectangle {
            background: Theme.accent-soft;
            border-radius: 3px;
            border-width: 1px;
            border-color: Theme.accent;
            height: 18px;
            width: shortcut-text.preferred-width + 10px;
            shortcut-text := Text {
                text: row-data.shortcut-text;
                color: Theme.text;
                font-size: 10px;
                horizontal-alignment: center;
                vertical-alignment: center;
                x: 5px;
                y: 0;
                height: parent.height;
            }
        }
        if row-data.is-locked : FaGlyph {
            glyph: "\u{f023}";
            glyph-size: 11px;
            tint: Theme.text-muted;
            width: 14px;
            height: parent.height;
        }
    }

    changed is-renaming => {
        if (root.is-renaming) {
            root.rename-focus-arm = true;
        } else {
            root.rename-focus-arm = false;
        }
    }

    ta := TouchArea {
        enabled: !root.is-renaming;
        clicked => { root.clicked(); }
        double-clicked => {
            if (row-data.is-folder) {
                root.toggle-collapse(root.row-index);
            } else {
                root.double-clicked();
            }
        }
        pointer-event(ev) => {
            if (ev.button == PointerEventButton.left && ev.kind == PointerEventKind.down) {
                root.drag-pressed(root.row-index, root.y + ta.mouse-y);
            } else if (ev.button == PointerEventButton.left && ev.kind == PointerEventKind.up) {
                root.drag-released(root.row-index, root.y + ta.mouse-y);
            }
        }
        moved => {
            root.drag-moved(root.row-index, root.y + self.mouse-y);
        }
    }
}

component LabeledLineEdit inherits Rectangle {
    in property <string> placeholder;
    in-out property <string> value;
    in property <int> sync-version: 0;
    in property <bool> read-only: false;
    in property <bool> password: false;
    callback edited(string);
    callback accepted(string);

    height: 32px;
    background: input.has-focus ? Theme.bg-input-focus : Theme.bg-input;
    border-width: 1px;
    border-color: Theme.border;
    border-radius: Theme.radius-sm;

    changed sync-version => {
        input.text = root.value;
    }

    input := TextInput {
        x: 8px;
        y: 0;
        width: parent.width - 16px;
        height: parent.height;
        text <=> root.value;
        color: Theme.text;
        font-size: 14px;
        horizontal-alignment: left;
        vertical-alignment: center;
        read-only: root.read-only;
        single-line: true;
        wrap: no-wrap;
        input-type: root.password ? InputType.password : InputType.text;
        selection-background-color: Theme.accent;
        selection-foreground-color: white;
        edited => { root.edited(self.text); }
        accepted => { root.accepted(self.text); }
    }

    if input.text == "" : Text {
        text: root.placeholder;
        color: Theme.text-muted;
        font-size: 14px;
        x: 8px;
        y: 0;
        height: parent.height;
        width: parent.width - 16px;
        vertical-alignment: center;
        horizontal-alignment: left;
        overflow: elide;
    }
}

component ThemedTextEdit inherits Rectangle {
    in property <string> placeholder-text: "";
    in property <string> font-family: Theme.ui-mono-font;
    in property <length> font-size: 13px;
    in property <bool> read-only: false;
    in property <bool> enabled: true;
    in property <TextWrap> wrap: TextWrap.word-wrap;
    in property <bool> sync-from-external: false;
    in property <string> external-text: "";
    in property <int> stamp: 0;
    in-out property <string> text <=> ti.text;

    callback edited(string);

    out property <bool> has-focus: ti.has-focus;

    forward-focus: ti;

    background: ti.has-focus ? Theme.bg-input-focus : Theme.bg-input;
    border-width: 1px;
    border-color: Theme.border;
    border-radius: Theme.radius-sm;

    property <length> pad: 8px;

    init => {
        if (root.sync-from-external) {
            ti.text = root.external-text;
        }
    }
    changed stamp => {
        if (root.sync-from-external) {
            ti.text = root.external-text;
        }
    }

    sv := ScrollView {
        x: root.pad;
        y: root.pad;
        width: parent.width - 2 * root.pad;
        height: parent.height - 2 * root.pad;
        viewport-width: root.wrap == TextWrap.no-wrap
            ? max(self.visible-width, ti.preferred-width)
            : self.visible-width;
        viewport-height: max(self.visible-height, ti.preferred-height);

        ti := TextInput {
            enabled: root.enabled;
            single-line: false;
            wrap: root.wrap;
            horizontal-alignment: left;
            read-only: root.read-only;
            font-size: root.font-size;
            font-family: root.font-family;
            color: Theme.text;
            selection-background-color: Theme.accent;
            selection-foreground-color: white;
            page-height: sv.visible-height;
            edited => {
                root.edited(self.text);
            }
            cursor-position-changed(cpos) => {
                if (cpos.x + sv.viewport-x < 12px) {
                    sv.viewport-x = min(0px, max(sv.visible-width - self.width, -cpos.x + 12px));
                } else if (cpos.x + sv.viewport-x > sv.visible-width - 12px) {
                    sv.viewport-x = min(0px, max(sv.visible-width - self.width, sv.visible-width - cpos.x - 12px));
                }
                if (cpos.y + sv.viewport-y < 12px) {
                    sv.viewport-y = min(0px, max(sv.visible-height - self.height, -cpos.y + 12px));
                } else if (cpos.y + sv.viewport-y > sv.visible-height - 12px - 20px) {
                    sv.viewport-y = min(0px, max(sv.visible-height - self.height, sv.visible-height - cpos.y - 12px - 20px));
                }
            }
        }
    }

    if ti.text == "" : Text {
        x: sv.x;
        y: sv.y;
        width: sv.width;
        vertical-alignment: top;
        text: root.placeholder-text;
        font-size: root.font-size;
        font-family: root.font-family;
        color: Theme.text-muted;
        overflow: elide;
    }
}

component ThemedComboBox inherits Rectangle {
    in property <[string]> model;
    in-out property <int> current-index: 0;
    in property <bool> enabled: true;
    callback selected(int);

    property <bool> popup-open: false;
    property <int> visible-rows: min(6, max(1, root.model.length));

    height: 32px;
    min-width: 160px;
    horizontal-stretch: 1;
    border-radius: Theme.radius-sm;
    border-width: 1px;
    border-color: Theme.border;
    background: root.popup-open || row-ta.has-hover
        ? Theme.bg-input-focus
        : Theme.bg-input;

    forward-focus: row-fs;

    changed model => {
        if (root.current-index < 0 || root.current-index >= root.model.length) {
            root.current-index = 0;
        }
    }

    row-fs := FocusScope {
        width: 100%;
        height: 100%;

        row-ta := TouchArea {
            enabled: root.enabled;
            clicked => {
                if (!root.enabled) {
                    return;
                }
                row-fs.focus();
                if (root.popup-open) {
                    popup.close();
                    root.popup-open = false;
                } else {
                    popup.show();
                    root.popup-open = true;
                }
            }

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 8px;
                spacing: 6px;
                alignment: stretch;
                combo-val := Text {
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                    color: Theme.text;
                    font-size: 14px;
                    text: root.current-index >= 0 && root.current-index < root.model.length
                        ? root.model[root.current-index]
                        : "";
                    overflow: elide;
                }
                Rectangle { horizontal-stretch: 1; }
                FaGlyph {
                    glyph: "\u{f078}";
                    weight: 900;
                    glyph-size: 11px;
                    tint: Theme.text-dim;
                    width: 14px;
                    y: (parent.height - self.height) / 2;
                }
            }
        }
    }

    popup := PopupWindow {
        x: 0;
        y: parent.height + 2px;
        width: root.width;
        height: root.visible-rows * 32px + 8px;
        close-policy: close-on-click-outside;
        forward-focus: inner-fs;

        inner-fs := FocusScope {
            width: 100%;
            height: 100%;
            focus-changed-event => {
                if (!self.has-focus) {
                    root.popup-open = false;
                }
            }

            Rectangle {
                width: 100%;
                height: 100%;
                background: Theme.bg-elev;
                border-width: 1px;
                border-color: Theme.border-strong;
                border-radius: Theme.radius-md;
                drop-shadow-blur: 12px;
                drop-shadow-color: Theme.is-light ? #00000022 : #00000088;

                ScrollView {
                    x: 4px;
                    y: 4px;
                    width: parent.width - 8px;
                    height: parent.height - 8px;
                    VerticalLayout {
                        spacing: 0;
                        alignment: start;
                        for entry[idx] in root.model : Rectangle {
                            height: 32px;
                            border-radius: Theme.radius-sm;
                            background: opt-ta.has-hover
                                ? Theme.bg-hover
                                : (idx == root.current-index ? Theme.accent-soft : transparent);
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                Text {
                                    text: entry;
                                    color: Theme.text;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                            }
                            opt-ta := TouchArea {
                                clicked => {
                                    root.current-index = idx;
                                    root.selected(idx);
                                    popup.close();
                                    root.popup-open = false;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

component HotkeyCapture inherits Rectangle {
    in property <string> hotkey-text;
    in property <string> placeholder: "Click and press a key combo...";
    in property <bool> read-only: false;
    in-out property <bool> capturing: false;
    callback key-captured(string, bool, bool, bool, bool);
    callback cleared();

    height: 32px;
    border-radius: Theme.radius-sm;
    border-width: root.capturing ? 1px : 1px;
    border-color: root.capturing ? Theme.accent : Theme.border;
    background: root.capturing
        ? Theme.accent-soft
        : (ta.has-hover && !root.read-only ? Theme.bg-input-focus : Theme.bg-input);

    Text {
        text: root.capturing
            ? "Press a key combination... (Esc to clear, click to cancel)"
            : (root.hotkey-text != "" ? root.hotkey-text : root.placeholder);
        color: root.capturing
            ? Theme.text
            : (root.hotkey-text != "" ? Theme.text : Theme.text-muted);
        font-size: 14px;
        font-weight: root.hotkey-text != "" && !root.capturing ? 600 : 400;
        horizontal-alignment: left;
        vertical-alignment: center;
        x: 10px;
        y: 0;
        width: parent.width - 20px;
        height: parent.height;
        overflow: elide;
    }

    ta := TouchArea {
        enabled: !root.read-only;
        clicked => {
            root.capturing = !root.capturing;
            if (root.capturing) { fs.focus(); }
        }
    }

    fs := FocusScope {
        x: 0; y: 0;
        width: 0; height: 0;
        enabled: root.capturing;
        key-pressed(event) => {
            if (event.text == Key.Control
                || event.text == Key.Alt
                || event.text == Key.Shift
                || event.text == Key.Meta) {
                return accept;
            }
            if (event.text == Key.Escape) {
                root.cleared();
                root.capturing = false;
                return accept;
            }
            root.key-captured(
                event.text,
                event.modifiers.control,
                event.modifiers.alt,
                event.modifiers.shift,
                event.modifiers.meta,
            );
            root.capturing = false;
            return accept;
        }
        changed has-focus => {
            if (!self.has-focus) { root.capturing = false; }
        }
    }
}

component FieldHelpIcon inherits Rectangle {
    in property <string> help-text;
    in property <string> hover-hint: @tr("Click for help");
    callback hover-changed(string);
    callback open-help(length, length, string);

    width: 22px;
    height: 22px;
    border-radius: 11px;
    background: ta.has-hover ? Theme.bg-hover : transparent;

    FaGlyph {
        glyph: "\u{f059}";
        weight: 400;
        glyph-size: 13px;
        tint: ta.has-hover ? Theme.accent : Theme.text-muted;
        width: parent.width;
        height: parent.height;
    }

    ta := TouchArea {
        clicked => {
            root.open-help(
                root.absolute-position.x + root.width + 6px,
                root.absolute-position.y + root.height + 4px,
                root.help-text,
            );
        }
        changed has-hover => {
            root.hover-changed(self.has-hover ? root.hover-hint : "");
        }
    }
}

component TokenChipBadge inherits Rectangle {
    in property <string> chip-text;
    in property <string> category;

    out property <color> fg:
          root.category == "date_clip" ? (Theme.is-light ? #0f4a6e : #7dd3fc)
        : root.category == "wait"      ? (Theme.is-light ? #5b2c83 : #e9d5ff)
        : root.category == "key"       ? (Theme.is-light ? #1f6a3a : #8ae0a8)
        : root.category == "var_include" ? (Theme.is-light ? #4338ca : #a5b4fc)
        : root.category == "database"  ? (Theme.is-light ? #9a3412 : #fed7aa)
        : root.category == "translation" ? (Theme.is-light ? #8a4a00 : #f3b766)
        : root.category == "branch"    ? (Theme.is-light ? #831843 : #fbcfe8)
        : Theme.text;
    out property <color> bg-chip:
          root.category == "date_clip" ? (Theme.is-light ? #cfe8f8 : #0c3d54)
        : root.category == "wait"      ? (Theme.is-light ? #ede4f7 : #3b0764)
        : root.category == "key"       ? (Theme.is-light ? #d6efdd : #1f3324)
        : root.category == "var_include" ? (Theme.is-light ? #e0e7ff : #1e1b4b)
        : root.category == "database"  ? (Theme.is-light ? #ffedd5 : #431407)
        : root.category == "translation" ? (Theme.is-light ? #ffe8c7 : #3c2a15)
        : root.category == "branch"    ? (Theme.is-light ? #fce7f3 : #500724)
        : Theme.bg-input;

    background: root.bg-chip;
    border-radius: Theme.radius-sm;
    height: 22px;
    width: chip-label.preferred-width + 14px;

    chip-label := Text {
        text: root.chip-text;
        color: root.fg;
        font-size: 11px;
        font-weight: 700;
        font-family: Theme.ui-mono-font;
        horizontal-alignment: center;
        vertical-alignment: center;
        x: 7px;
        y: 0;
        height: parent.height;
    }
}

component TokenChipStrip inherits Rectangle {
    in property <[TokenChip]> chips;

    height: root.chips.length > 0 ? 28px : 0;
    background: transparent;

    if root.chips.length > 0 : ScrollView {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        viewport-height: parent.height;

        HorizontalLayout {
            spacing: 4px;
            padding-left: 4px;
            padding-right: 4px;
            alignment: start;

            for chip[i] in root.chips : TokenChipBadge {
                chip-text: chip.text;
                category: chip.category;
            }
        }
    }
}

export component MainWindow inherits Window {
    default-font-family: Theme.ui-font;
    default-font-weight: 400;

    title: root.is_admin_edition ? @tr("Poltergeist [ADMIN]") : @tr("Poltergeist");
    icon: root.is_admin_edition
        ? @image-url("../../../assets/AppIconAdmin.png")
        : @image-url("../../../assets/AppIcon.png");
    background: Theme.bg;
    preferred-width: 1080px;
    preferred-height: 720px;
    min-width: 860px;
    min-height: 560px;

    in property <string> status_text;
    in property <string> editor_hint_text: "";
    in property <int> editor_sync_version: 0;
    in property <[TreeRowData]> personal_tree_rows;
    in property <[TreeRowData]> team_tree_rows;
    in property <string> selected_personal_kind: "none";
    in property <string> selected_personal_name;
    in property <string> selected_personal_text;
    in property <string> selected_personal_shortcut;
    in property <string> selected_personal_match_expr;
    in-out property <int> selected_personal_injection_index: 0;
    in property <bool> selected_personal_prompt_untranslated: true;
    in-out property <string> selected_personal_color_text;
    in property <color> selected_personal_color;
    in property <bool> selected_personal_has_color;
    in property <string> selected_team_kind: "none";
    in property <string> selected_team_name;
    in property <string> selected_team_text;
    in property <string> selected_team_shortcut;
    in property <string> selected_team_match_expr;
    in-out property <string> selected_team_color_text;
    in property <color> selected_team_color;
    in property <bool> selected_team_has_color;
    in property <[TokenChip]> personal_tokens;
    in property <[TokenChip]> team_tokens;
    in property <bool> hotkeys_paused;
    in property <bool> is_admin_edition;
    in-out property <bool> is_light_theme: false;

    in-out property <string> hotkey_text;
    in-out property <string> date_format_text;
    in property <string> date_format_preview_text;
    in-out property <int> default_injection_index: 0;
    in-out property <int> theme_index: 0;
    in property <[string]> available_languages: ["English", "Deutsch", "Español", "Français"];
    in-out property <int> language_index: 0;
    in property <bool> start_with_windows: false;
    in-out property <string> deepl_api_key_text;
    in-out property <bool> deepl_key_visible: false;
    in property <string> deepl_status_text;
    in property <int> deepl_status_kind: 0;
    in-out property <string> team_share_text;
    in property <string> team_share_status_text;
    in property <int> team_share_status_kind: 0;
    in-out property <string> context_patterns_text;
    in property <string> app_version_text: "0.1.0 (dev)";

    in-out property <bool> show_options_panel: false;
    in-out property <int> options_tab_index: 0;
    in-out property <bool> show_about_panel: false;
    in-out property <bool> show_team_panel: false;
    in-out property <string> hover_tooltip_text;

    in-out property <bool> show_review_panel: false;
    in-out property <string> review_text;

    in-out property <bool> show_picker_panel: false;
    in property <[NodePickerRow]> picker_rows;
    in property <string> picker_title: "";
    in property <string> picker_subtitle: "";
    in property <string> picker_ok_label: "OK";
    in property <string> picker_summary: "";
    in property <bool> picker_can_accept: false;

    in-out property <bool> show_confirm_panel: false;
    in property <string> confirm_title: "";
    in property <string> confirm_message: "";
    in property <string> confirm_yes_label: @tr("Yes");
    in property <string> confirm_no_label: @tr("No");
    in property <string> confirm_cancel_label: @tr("Cancel");
    in property <bool> confirm_show_no: true;
    in property <bool> confirm_show_cancel: true;
    in property <string> confirm_kind: "";

    in-out property <bool> show_translation_picker: false;
    in property <[string]> translation_source_options;
    in property <[string]> translation_target_options;
    in-out property <int> translation_source_index: 0;
    in-out property <int> translation_target_index: 0;
    in-out property <string> translation_picker_target: "personal";

    in-out property <int> drag-source-index: -1;
    in-out property <length> drag-press-y;
    in-out property <length> drag-current-y;
    in-out property <bool> drag-active: false;
    in-out property <int> drop-above-index: -1;
    in-out property <int> drop-into-index: -1;

    in-out property <bool> help_visible: false;
    in-out property <string> help_text: "";
    in-out property <length> help_anchor_x: 0px;
    in-out property <length> help_anchor_y: 0px;

    out property <string> show_when_help_text:
          "Filter: only show this snippet in the popup when the context matches.\n"
        + "Clauses separated by ';' (all must be true).\n"
        + "Operators (all case-insensitive):\n"
        + "  =, !=, in, not in, contains, startswith, endswith, matches\n"
        + "Variables come from the Context patterns in Options.\n"
        + "\n"
        + "Suffix any operator with '?' to also show this snippet when "
        + "the variable is empty / missing — useful when the user forgot "
        + "to select text (e.g. 'type contains? Sto').\n"
        + "\n"
        + "Use 'hide' on its own to hide this snippet from the popup "
        + "entirely — handy for helper snippets meant only for "
        + "{INCLUDE=...}.";

    in-out property <bool> show_token_popup: false;
    in-out property <length> token_popup_x;
    in-out property <length> token_popup_y;
    in-out property <int> token_popup_page: 0;
    in-out property <string> token_popup_target: "personal";
    in-out property <string> token_popup_input_kind: "";
    in-out property <string> token_popup_input_value: "";
    in-out property <string> token_popup_input_label: "";
    in-out property <string> token_popup_input_placeholder: "";
    in-out property <string> token_popup_input_help: "";

    in-out property <bool> show_color_popup: false;
    in-out property <length> color_popup_x;
    in-out property <length> color_popup_y;
    in-out property <string> color_popup_target: "personal";
    in-out property <string> options_accent_hex: "#5865f2";
    in property <color> options_accent_preview: #5865f2;
    in property <[ColorSwatchRow]> color_swatch_row_top: [];
    in property <[ColorSwatchRow]> color_swatch_row_bottom: [];
    in-out property <bool> show_personal_hotkey_popup: false;
    in-out property <length> personal_hotkey_popup_x;
    in-out property <length> personal_hotkey_popup_y;
    in-out property <bool> show_team_hotkey_popup: false;
    in-out property <length> team_hotkey_popup_x;
    in-out property <length> team_hotkey_popup_y;

    in-out property <int> rename_personal_active_index: -1;
    in-out property <int> rename_team_active_index: -1;
    in property <int> selected_personal_index: -1;
    in property <int> selected_team_index: -1;

    in property <int> save_state_kind: 0;
    in property <string> save_status_text: "Auto-save ready";

    init => {
        Theme.is-light = root.is_light_theme;
        Palette.color-scheme = root.is-light-theme ? ColorScheme.light : ColorScheme.dark;
    }
    changed is_light_theme => {
        Theme.is-light = root.is_light_theme;
        Palette.color-scheme = root.is-light-theme ? ColorScheme.light : ColorScheme.dark;
    }
    changed show_options_panel => { root.options_panel_visibility(root.show_options_panel); }

    callback main_window_geometry_changed();
    changed width => {
        root.main_window_geometry_changed();
    }
    changed height => {
        root.main_window_geometry_changed();
    }

    callback request_save();
    callback exit_app();
    callback toggle_theme();
    callback toggle_hotkeys();
    callback open_popup();
    callback close_popup();
    callback confirm_review(string);
    callback cancel_review();
    callback picker_toggle_check(int);
    callback picker_toggle_expand(int);
    callback picker_select_all();
    callback picker_clear_all();
    callback picker_accept();
    callback picker_cancel();
    callback confirm_yes(string);
    callback confirm_no(string);
    callback confirm_cancel(string);
    callback accept_translation_picker(int, int, string);
    callback select_personal_row(int);
    callback add_personal_folder();
    callback add_personal_snippet();
    callback delete_personal_selected();
    callback rename_personal_selected(string);
    callback update_personal_text(string);
    callback update_personal_shortcut(string);
    callback update_personal_match_expr(string);
    callback update_personal_injection_index(int);
    callback update_personal_prompt_untranslated(bool);
    callback insert_personal_token(string);
    callback insert_team_token(string);
    callback build_and_insert_token(string, string, string);
    callback import_personal();
    callback export_personal();
    callback move_personal(int, int, bool);
    callback toggle_personal_folder(int);
    callback set_personal_color(string);
    callback select_team_row(int);
    callback add_team_folder();
    callback add_team_snippet();
    callback delete_team_selected();
    callback rename_team_selected(string);
    callback update_team_text(string);
    callback update_team_shortcut(string);
    callback update_team_match_expr(string);
    callback copy_team_text();
    callback import_team();
    callback export_team();
    callback publish_team_pack();
    callback refresh_team_pack();
    callback move_team(int, int, bool);
    callback toggle_team_folder(int);
    callback set_team_color(string);
    callback apply_settings(string, string, int, string, string, int, int, string, bool, string);
    callback options_panel_visibility(bool);
    callback preview_options_accent(string);
    callback validate_deepl_key();
    callback deepl_key_edited(string);
    callback open_github();
    callback date_format_edited(string);
    callback open_url(string);
    pure callback format_hotkey(string, bool, bool, bool, bool) -> string;

    function is-personal() -> bool { return !root.show_team_panel; }
    VerticalLayout {
        padding: 0;
        spacing: 0;

        Rectangle {
            background: Theme.bg-elev;
            height: 52px;
            border-color: Theme.border;
            border-width: 0;
            Rectangle {
                x: 0;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: Theme.border;
            }
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 4px;

                IconButton {
                    glyph: "\u{f019}"; glyph-weight: 900;
                    tooltip-text: @tr("Import snippets…");
                    enabled: root.is_admin_edition || root.is-personal();
                    clicked => {
                        if (root.is-personal()) { root.import_personal(); } else { root.import_team(); }
                        root.request_save();
                    }
                    hover-changed(t) => { root.hover_tooltip_text = t; }
                }
                IconButton {
                    glyph: "\u{f093}"; glyph-weight: 900;
                    tooltip-text: @tr("Export snippets…");
                    clicked => {
                        if (root.is-personal()) { root.export_personal(); } else { root.export_team(); }
                    }
                    hover-changed(t) => { root.hover_tooltip_text = t; }
                }
                if root.is_admin_edition && root.show_team_panel : IconButton {
                    glyph: "\u{f1d8}"; glyph-weight: 400;
                    tooltip-text: @tr("Publish team pack");
                    success: true;
                    clicked => { root.publish_team_pack(); }
                    hover-changed(t) => { root.hover_tooltip_text = t; }
                }
                if root.show_team_panel : IconButton {
                    glyph: "\u{f021}"; glyph-weight: 900;
                    tooltip-text: @tr("Refresh team pack from share");
                    clicked => { root.refresh_team_pack(); }
                    hover-changed(t) => { root.hover_tooltip_text = t; }
                }
                save-btn := Rectangle {
                    width: 36px;
                    height: 36px;
                    y: (parent.height - 36px) / 2;
                    border-radius: Theme.radius-md;
                    background: save-ta.has-hover ? Theme.bg-hover : transparent;
                    border-width: save-ta.has-hover ? 1px : 0;
                    border-color: Theme.border;
                    FaGlyph {
                        glyph: "\u{f0c7}";
                        weight: 900;
                        glyph-size: save-btn.width * 0.45;
                        tint: root.save_state_kind == 1
                            ? Theme.warning
                            : (root.save_state_kind == 2
                                ? Theme.success
                                : Theme.text-muted);
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height;
                    }
                    save-ta := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        changed has-hover => {
                            root.hover_tooltip_text = self.has-hover
                                ? root.save_status_text
                                : "";
                        }
                    }
                }

                Rectangle { horizontal-stretch: 1; }

                if root.hotkeys_paused : Rectangle {
                    background: Theme.warning.with-alpha(0.18);
                    border-color: Theme.warning;
                    border-width: 1px;
                    border-radius: Theme.radius-sm;
                    height: 24px;
                    width: paused-text.preferred-width + 18px;
                    y: (parent.height - 24px) / 2;
                    paused-text := Text {
                        text: @tr("Hotkeys paused");
                        color: Theme.warning;
                        font-size: 11px;
                        font-weight: 700;
                        x: 9px;
                        height: parent.height;
                        vertical-alignment: center;
                    }
                }

                IconButton {
                    glyph: root.is_light_theme ? "\u{f186}" : "\u{f185}"; glyph-weight: 400;
                    tooltip-text: root.is_light_theme ? @tr("Switch to dark theme") : @tr("Switch to light theme");
                    clicked => { root.toggle_theme(); }
                    hover-changed(t) => { root.hover_tooltip_text = t; }
                }
                IconButton {
                    glyph: "\u{f013}"; glyph-weight: 900;
                    tooltip-text: @tr("Options…");
                    active: root.show_options_panel;
                    clicked => {
                        root.show_options_panel = !root.show_options_panel;
                    }
                    hover-changed(t) => { root.hover_tooltip_text = t; }
                }
                IconButton {
                    glyph: "\u{f05a}"; glyph-weight: 900;
                    tooltip-text: @tr("About Poltergeist");
                    active: root.show_about_panel;
                    clicked => {
                        root.show_about_panel = !root.show_about_panel;
                    }
                    hover-changed(t) => { root.hover_tooltip_text = t; }
                }
            }
        }

        Rectangle {
            background: Theme.bg;
            height: 38px;
            Rectangle {
                x: 0;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: Theme.border;
            }
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 4px;
                alignment: start;
                TabButton {
                    label: @tr("Personal");
                    icon-glyph: "\u{f007}";
                    active: !root.show_team_panel;
                    clicked => { root.show_team_panel = false; }
                    width: 140px;
                    y: (parent.height - self.height) / 2;
                }
                TabButton {
                    label: @tr("Team");
                    icon-glyph: "\u{f0c0}";
                    trailing-glyph: root.is_admin_edition ? "\u{f3c1}" : "\u{f023}";
                    trailing-tint: root.is_admin_edition ? Theme.success : Theme.text-muted;
                    active: root.show_team_panel;
                    clicked => { root.show_team_panel = true; }
                    width: 140px;
                    y: (parent.height - self.height) / 2;
                }
            }
        }

        Rectangle {
            background: Theme.bg-elev;
            vertical-stretch: 1;

            HorizontalLayout {
                padding: 0;
                spacing: 0;

                Rectangle {
                    width: 320px;
                    VerticalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 6px;

                        Rectangle {
                            vertical-stretch: 1;
                            tree-fs := FocusScope {
                                x: 0;
                                y: 0;
                                width: parent.width;
                                height: parent.height;
                                key-pressed(event) => {
                                    if (event.text == Key.F2) {
                                        if (root.show_team_panel
                                            && root.is_admin_edition
                                            && root.selected_team_index >= 0) {
                                            root.rename_team_active_index = root.selected_team_index;
                                            return accept;
                                        } else if (!root.show_team_panel
                                            && root.selected_personal_index >= 0) {
                                            root.rename_personal_active_index = root.selected_personal_index;
                                            return accept;
                                        }
                                    }
                                    if (event.text == Key.Delete) {
                                        if (root.show_team_panel
                                            && root.is_admin_edition
                                            && root.selected_team_kind != "none") {
                                            root.delete_team_selected();
                                            root.request_save();
                                            return accept;
                                        } else if (!root.show_team_panel
                                            && root.selected_personal_kind != "none") {
                                            root.delete_personal_selected();
                                            root.request_save();
                                            return accept;
                                        }
                                    }
                                    return reject;
                                }
                            ScrollView {
                                x: 0;
                                y: 0;
                                width: parent.width;
                                height: parent.height;
                                if !root.show_team_panel : VerticalLayout {
                                    spacing: 1px;
                                    for row[idx] in root.personal_tree_rows : TreeRow {
                                        row-data: row;
                                        row-index: idx;
                                        is-drop-source: root.drag-active && root.drag-source-index == idx;
                                        is-drop-above: root.drag-active && root.drop-above-index == idx;
                                        is-drop-into: root.drag-active && root.drop-into-index == idx;
                                        is-renaming: root.rename_personal_active_index == idx;
                                        clicked => {
                                            if (root.rename_personal_active_index != -1
                                                && root.rename_personal_active_index != idx) {
                                                root.rename_personal_active_index = -1;
                                            }
                                            tree-fs.focus();
                                            root.select_personal_row(idx);
                                        }
                                        double-clicked => {
                                            root.select_personal_row(idx);
                                            root.rename_personal_active_index = idx;
                                        }
                                        toggle-collapse(i) => { tree-fs.focus(); root.toggle_personal_folder(i); }
                                        rename-submit(i, t) => {
                                            root.rename_personal_active_index = -1;
                                            root.rename_personal_selected(t);
                                            root.request_save();
                                            tree-fs.focus();
                                        }
                                        rename-cancel(i) => {
                                            root.rename_personal_active_index = -1;
                                            tree-fs.focus();
                                        }
                                        drag-pressed(i, y) => {
                                            root.drag-source-index = i;
                                            root.drag-press-y = y;
                                            root.drag-current-y = y;
                                            root.drag-active = false;
                                        }
                                        drag-moved(i, y) => {
                                            root.drag-current-y = y;
                                            if (!root.drag-active &&
                                                abs(y - root.drag-press-y) > 14px &&
                                                root.drag-source-index >= 0) {
                                                root.drag-active = true;
                                            }
                                            if (root.drag-active) {
                                                root.drop-above-index = max(0, min(
                                                    root.personal_tree_rows.length - 1,
                                                    floor(y / 27px)));
                                                if (root.personal_tree_rows[root.drop-above-index].is-folder &&
                                                    (mod(y / 1px, 27) > 7 && mod(y / 1px, 27) < 20)) {
                                                    root.drop-into-index = root.drop-above-index;
                                                } else {
                                                    root.drop-into-index = -1;
                                                }
                                            }
                                        }
                                        drag-released(i, y) => {
                                            if (root.drag-active && root.drag-source-index >= 0) {
                                                root.move_personal(
                                                    root.drag-source-index,
                                                    root.drop-above-index,
                                                    root.drop-into-index >= 0
                                                );
                                                root.request_save();
                                            }
                                            root.drag-source-index = -1;
                                            root.drag-active = false;
                                            root.drop-above-index = -1;
                                            root.drop-into-index = -1;
                                        }
                                    }
                                }
                                if root.show_team_panel : VerticalLayout {
                                    spacing: 1px;
                                    for row[idx] in root.team_tree_rows : TreeRow {
                                        row-data: row;
                                        row-index: idx;
                                        is-drop-source: root.drag-active && root.drag-source-index == idx;
                                        is-drop-above: root.drag-active && root.drop-above-index == idx;
                                        is-drop-into: root.drag-active && root.drop-into-index == idx;
                                        is-renaming: root.rename_team_active_index == idx;
                                        clicked => {
                                            if (root.rename_team_active_index != -1
                                                && root.rename_team_active_index != idx) {
                                                root.rename_team_active_index = -1;
                                            }
                                            tree-fs.focus();
                                            root.select_team_row(idx);
                                        }
                                        double-clicked => {
                                            root.select_team_row(idx);
                                            if (root.is_admin_edition) {
                                                root.rename_team_active_index = idx;
                                            }
                                        }
                                        toggle-collapse(i) => { tree-fs.focus(); root.toggle_team_folder(i); }
                                        rename-submit(i, t) => {
                                            root.rename_team_active_index = -1;
                                            if (root.is_admin_edition) {
                                                root.rename_team_selected(t);
                                                root.request_save();
                                            }
                                            tree-fs.focus();
                                        }
                                        rename-cancel(i) => {
                                            root.rename_team_active_index = -1;
                                            tree-fs.focus();
                                        }
                                        drag-pressed(i, y) => {
                                            if (root.is_admin_edition) {
                                                root.drag-source-index = i;
                                                root.drag-press-y = y;
                                                root.drag-current-y = y;
                                                root.drag-active = false;
                                            }
                                        }
                                        drag-moved(i, y) => {
                                            if (root.is_admin_edition && root.drag-source-index >= 0) {
                                                root.drag-current-y = y;
                                                if (!root.drag-active && abs(y - root.drag-press-y) > 14px) {
                                                    root.drag-active = true;
                                                }
                                                if (root.drag-active) {
                                                    root.drop-above-index = max(0, min(
                                                        root.team_tree_rows.length - 1,
                                                        floor(y / 27px)));
                                                    if (root.team_tree_rows[root.drop-above-index].is-folder &&
                                                        (mod(y / 1px, 27) > 7 && mod(y / 1px, 27) < 20)) {
                                                        root.drop-into-index = root.drop-above-index;
                                                    } else {
                                                        root.drop-into-index = -1;
                                                    }
                                                }
                                            }
                                        }
                                        drag-released(i, y) => {
                                            if (root.drag-active && root.drag-source-index >= 0) {
                                                root.move_team(
                                                    root.drag-source-index,
                                                    root.drop-above-index,
                                                    root.drop-into-index >= 0
                                                );
                                                root.request_save();
                                            }
                                            root.drag-source-index = -1;
                                            root.drag-active = false;
                                            root.drop-above-index = -1;
                                            root.drop-into-index = -1;
                                        }
                                    }
                                }
                            }
                            }
                        }

                        if !root.show_team_panel : HorizontalLayout {
                            spacing: 4px;
                            IconButton {
                                btn-size: 30px;
                                glyph: "\u{f07c}"; glyph-weight: 400;
                                tooltip-text: @tr("New folder");
                                clicked => { root.add_personal_folder(); root.request_save(); }
                                hover-changed(t) => { root.hover_tooltip_text = t; }
                            }
                            IconButton {
                                btn-size: 30px;
                                glyph: "\u{f15b}"; glyph-weight: 400;
                                tooltip-text: @tr("New snippet");
                                clicked => { root.add_personal_snippet(); root.request_save(); }
                                hover-changed(t) => { root.hover_tooltip_text = t; }
                            }
                            IconButton {
                                btn-size: 30px;
                                glyph: "\u{f044}"; glyph-weight: 400;
                                tooltip-text: @tr("Rename selected (F2)");
                                clicked => {
                                    if (root.selected_personal_index >= 0) {
                                        root.rename_personal_active_index = root.selected_personal_index;
                                    }
                                }
                                hover-changed(t) => { root.hover_tooltip_text = t; }
                            }
                            IconButton {
                                btn-size: 30px;
                                glyph: "\u{f2ed}"; glyph-weight: 900;
                                tooltip-text: @tr("Delete");
                                destructive: true;
                                clicked => { root.delete_personal_selected(); root.request_save(); }
                                hover-changed(t) => { root.hover_tooltip_text = t; }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            Text {
                                text: root.personal_tree_rows.length + " items";
                                color: Theme.text-muted;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }
                        if root.show_team_panel : HorizontalLayout {
                            spacing: 4px;
                            IconButton {
                                btn-size: 30px;
                                glyph: "\u{f07c}"; glyph-weight: 400;
                                tooltip-text: @tr("New folder");
                                enabled: root.is_admin_edition;
                                clicked => { root.add_team_folder(); root.request_save(); }
                                hover-changed(t) => { root.hover_tooltip_text = t; }
                            }
                            IconButton {
                                btn-size: 30px;
                                glyph: "\u{f15b}"; glyph-weight: 400;
                                tooltip-text: @tr("New snippet");
                                enabled: root.is_admin_edition;
                                clicked => { root.add_team_snippet(); root.request_save(); }
                                hover-changed(t) => { root.hover_tooltip_text = t; }
                            }
                            IconButton {
                                btn-size: 30px;
                                glyph: "\u{f044}"; glyph-weight: 400;
                                tooltip-text: @tr("Rename selected (F2)");
                                enabled: root.is_admin_edition;
                                clicked => {
                                    if (root.is_admin_edition && root.selected_team_index >= 0) {
                                        root.rename_team_active_index = root.selected_team_index;
                                    }
                                }
                                hover-changed(t) => { root.hover_tooltip_text = t; }
                            }
                            IconButton {
                                btn-size: 30px;
                                glyph: "\u{f2ed}"; glyph-weight: 900;
                                tooltip-text: @tr("Delete");
                                destructive: true;
                                enabled: root.is_admin_edition;
                                clicked => { root.delete_team_selected(); root.request_save(); }
                                hover-changed(t) => { root.hover_tooltip_text = t; }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            Text {
                                text: root.team_tree_rows.length + " items";
                                color: Theme.text-muted;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                Rectangle {
                    width: 1px;
                    background: Theme.border;
                }

                Rectangle {
                    horizontal-stretch: 1;

                    if !root.show_team_panel : VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 12px;
                        padding-bottom: 12px;
                        spacing: 10px;
                        if root.selected_personal_kind == "none" : Text {
                            text: @tr("Select a folder or snippet on the left to start editing.");
                            color: Theme.text-muted;
                            font-size: 12px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                        }

                        if root.selected_personal_kind != "none" : VerticalLayout {
                            spacing: 10px;

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: stretch;
                                FieldLabel {
                                    text: @tr("Show when");
                                    compact: true;
                                }
                                FieldHelpIcon {
                                    help-text: root.show_when_help_text;
                                    hover-hint: @tr("Click for filter help");
                                    hover-changed(t) => { root.hover_tooltip_text = t; }
                                    open-help(x, y, t) => {
                                        root.help_anchor_x = x;
                                        root.help_anchor_y = y;
                                        root.help_text = t;
                                        root.help_visible = true;
                                    }
                                }
                                LabeledLineEdit {
                                    sync-version: root.editor_sync_version;
                                    value: root.selected_personal_match_expr;
                                    placeholder: @tr("e.g. country = DE; type contains Sto  (empty = always)");
                                    horizontal-stretch: 1;
                                    accepted(t) => { root.update_personal_match_expr(t); root.request_save(); }
                                }
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: stretch;
                                Rectangle {
                                    width: 40px;
                                    height: 32px;
                                    border-radius: Theme.radius-sm;
                                    border-width: 1px;
                                    border-color: Theme.border;
                                    background: p-col-ta.has-hover ? Theme.bg-hover : Theme.bg-input;
                                    Rectangle {
                                        x: (parent.width - 20px) / 2;
                                        y: (parent.height - 20px) / 2;
                                        width: 20px;
                                        height: 20px;
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: Theme.border-strong;
                                        background: root.selected_personal_has_color
                                            ? root.selected_personal_color
                                            : Theme.text-muted;
                                    }
                                    p-col-ta := TouchArea {
                                        clicked => {
                                            root.color_popup_target = "personal";
                                            root.color_popup_x =
                                                self.absolute-position.x
                                                + (self.width - 216px) / 2;
                                            root.color_popup_y =
                                                self.absolute-position.y + self.height + 4px;
                                            root.show_color_popup = true;
                                        }
                                    }
                                }
                                if root.selected_personal_kind == "folder" : Rectangle {
                                    width: 44px;
                                    height: 32px;
                                    border-radius: Theme.radius-sm;
                                    border-width: 1px;
                                    border-color: Theme.border;
                                    background: p-hk-ta.has-hover ? Theme.bg-hover : Theme.bg-input;
                                    FaGlyph {
                                        glyph: "\u{f11c}";
                                        weight: 400;
                                        glyph-size: 16px;
                                        tint: Theme.text-dim;
                                        width: parent.width;
                                        height: parent.height;
                                    }
                                    p-hk-ta := TouchArea {
                                        clicked => {
                                            root.personal_hotkey_popup_x =
                                                self.absolute-position.x + self.width - 280px;
                                            root.personal_hotkey_popup_y =
                                                self.absolute-position.y + self.height + 4px;
                                            root.show_personal_hotkey_popup = true;
                                        }
                                    }
                                }
                                if root.selected_personal_kind == "snippet" : Rectangle {
                                    width: 44px;
                                    height: 32px;
                                    border-radius: Theme.radius-sm;
                                    border-width: 1px;
                                    border-color: Theme.border;
                                    background: p-tr-ta.has-hover
                                        ? Theme.bg-hover
                                        : (root.selected_personal_prompt_untranslated
                                            ? Theme.accent-soft
                                            : Theme.bg-input);
                                    FaGlyph {
                                        glyph: "\u{f1ab}";
                                        weight: 900;
                                        glyph-size: 15px;
                                        tint: root.selected_personal_prompt_untranslated
                                            ? Theme.accent
                                            : Theme.text-dim;
                                        width: parent.width;
                                        height: parent.height;
                                    }
                                    p-tr-ta := TouchArea {
                                        clicked => {
                                            root.update_personal_prompt_untranslated(
                                                !root.selected_personal_prompt_untranslated,
                                            );
                                            root.request_save();
                                        }
                                    }
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                    height: 1px;
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: end;
                                    if root.selected_personal_kind == "snippet" : ThemedComboBox {
                                        width: 220px;
                                        model: [@tr("Default"), @tr("Clipboard (Ctrl+V)"), @tr("Clipboard (Shift+Ins)"), @tr("Typing (key events)"), @tr("Typing (web compat)")];
                                        current-index <=> root.selected_personal_injection_index;
                                        selected(idx) => {
                                            root.update_personal_injection_index(idx);
                                            root.request_save();
                                        }
                                    }
                                    if root.selected_personal_kind == "folder" : Rectangle {
                                        width: 220px;
                                        height: 32px;
                                        background: transparent;
                                    }
                                    if root.selected_personal_kind == "snippet" : token-anchor := Rectangle {
                                        width: 36px;
                                        height: 32px;
                                        border-radius: Theme.radius-sm;
                                        background: tt.has-hover ? Theme.bg-hover : Theme.bg-input;
                                        border-color: Theme.border;
                                        border-width: 1px;
                                        FaGlyph {
                                            glyph: "\u{f073}";
                                            weight: 400;
                                            glyph-size: 14px;
                                            tint: Theme.text-dim;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                        tt := TouchArea {
                                            clicked => {
                                                root.token_popup_x =
                                                    token-anchor.absolute-position.x
                                                    + token-anchor.width - 320px;
                                                root.token_popup_y =
                                                    token-anchor.absolute-position.y
                                                    + token-anchor.height + 4px;
                                                root.token_popup_target = "personal";
                                                root.token_popup_page = 0;
                                                root.show_token_popup = true;
                                            }
                                        }
                                    }
                                    if root.selected_personal_kind == "folder" : Rectangle {
                                        width: 36px;
                                        height: 32px;
                                        background: transparent;
                                    }
                                }
                            }

                            if root.selected_personal_kind == "snippet" : VerticalLayout {
                                spacing: 4px;
                                vertical-stretch: 1;
                                body-edit := ThemedTextEdit {
                                    vertical-stretch: 1;
                                    sync-from-external: true;
                                    external-text: root.selected_personal_text;
                                    stamp: root.editor_sync_version;
                                    font-family: Theme.ui-mono-font;
                                    font-size: 13px;
                                    placeholder-text: @tr("Type or paste the snippet text here…\nUse the Insert Token menu (or type {{DATE}}, {{TAB}}, {{ENTER}}, {{CLIPBOARD}}).");
                                    wrap: word-wrap;
                                    edited(t) => { root.update_personal_text(t); root.request_save(); }
                                }
                                TokenChipStrip { chips: root.personal_tokens; }
                            }

                            if root.selected_personal_kind == "folder" : Rectangle {
                                background: Theme.bg-input;
                                border-width: 1px;
                                border-color: Theme.border;
                                border-radius: Theme.radius-sm;
                                vertical-stretch: 1;
                                VerticalBox {
                                    padding: 16px;
                                    spacing: 8px;
                                    Text {
                                        text: @tr("Folder properties");
                                        color: Theme.text;
                                        font-size: 13px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text: @tr("Folders group related snippets and can have their own match filter and global hotkey. Children of a hidden folder stay hidden in the popup.");
                                        color: Theme.text-dim;
                                        font-size: 12px;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }

                    if root.show_team_panel : VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 12px;
                        padding-bottom: 12px;
                        spacing: 10px;

                        if root.selected_team_kind != "none" : VerticalLayout {
                            spacing: 10px;
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: stretch;
                                FieldLabel {
                                    text: @tr("Show when");
                                    compact: true;
                                }
                                FieldHelpIcon {
                                    help-text: root.show_when_help_text;
                                    hover-hint: @tr("Click for filter help");
                                    hover-changed(t) => { root.hover_tooltip_text = t; }
                                    open-help(x, y, t) => {
                                        root.help_anchor_x = x;
                                        root.help_anchor_y = y;
                                        root.help_text = t;
                                        root.help_visible = true;
                                    }
                                }
                                LabeledLineEdit {
                                    sync-version: root.editor_sync_version;
                                    value: root.selected_team_match_expr;
                                    placeholder: @tr("e.g. country = DE; type contains Sto  (empty = always)");
                                    read-only: !root.is_admin_edition;
                                    horizontal-stretch: 1;
                                    accepted(t) => {
                                        if (root.is_admin_edition) { root.update_team_match_expr(t); root.request_save(); }
                                    }
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: stretch;
                                Rectangle {
                                    width: 40px;
                                    height: 32px;
                                    border-radius: Theme.radius-sm;
                                    border-width: 1px;
                                    border-color: Theme.border;
                                    background: t-col-ta.has-hover ? Theme.bg-hover : Theme.bg-input;
                                    opacity: root.is_admin_edition ? 1.0 : 0.45;
                                    Rectangle {
                                        x: (parent.width - 20px) / 2;
                                        y: (parent.height - 20px) / 2;
                                        width: 20px;
                                        height: 20px;
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: Theme.border-strong;
                                        background: root.selected_team_has_color
                                            ? root.selected_team_color
                                            : Theme.text-muted;
                                    }
                                    t-col-ta := TouchArea {
                                        enabled: root.is_admin_edition;
                                        clicked => {
                                            if (root.is_admin_edition) {
                                                root.color_popup_target = "team";
                                                root.color_popup_x =
                                                    self.absolute-position.x
                                                    + (self.width - 216px) / 2;
                                                root.color_popup_y =
                                                    self.absolute-position.y + self.height + 4px;
                                                root.show_color_popup = true;
                                            }
                                        }
                                    }
                                }
                                if root.selected_team_kind == "folder" : Rectangle {
                                    width: 44px;
                                    height: 32px;
                                    border-radius: Theme.radius-sm;
                                    border-width: 1px;
                                    border-color: Theme.border;
                                    background: t-hk-ta.has-hover ? Theme.bg-hover : Theme.bg-input;
                                    FaGlyph {
                                        glyph: "\u{f11c}";
                                        weight: 400;
                                        glyph-size: 16px;
                                        tint: Theme.text-dim;
                                        width: parent.width;
                                        height: parent.height;
                                    }
                                    t-hk-ta := TouchArea {
                                        clicked => {
                                            root.team_hotkey_popup_x =
                                                self.absolute-position.x + self.width - 280px;
                                            root.team_hotkey_popup_y =
                                                self.absolute-position.y + self.height + 4px;
                                            root.show_team_hotkey_popup = true;
                                        }
                                    }
                                }
                                if root.selected_team_kind == "snippet" : Rectangle {
                                    width: 44px;
                                    height: 32px;
                                    background: transparent;
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                    height: 1px;
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: end;
                                    Rectangle {
                                        width: 220px;
                                        height: 32px;
                                        background: transparent;
                                    }
                                    if root.selected_team_kind == "snippet" && root.is_admin_edition : team-token-anchor := Rectangle {
                                        width: 36px;
                                        height: 32px;
                                        border-radius: Theme.radius-sm;
                                        background: tta.has-hover ? Theme.bg-hover : Theme.bg-input;
                                        border-color: Theme.border;
                                        border-width: 1px;
                                        FaGlyph {
                                            glyph: "\u{f073}";
                                            weight: 400;
                                            glyph-size: 14px;
                                            tint: Theme.text-dim;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                        tta := TouchArea {
                                            clicked => {
                                                root.token_popup_x =
                                                    team-token-anchor.absolute-position.x
                                                    + team-token-anchor.width - 320px;
                                                root.token_popup_y =
                                                    team-token-anchor.absolute-position.y
                                                    + team-token-anchor.height + 4px;
                                                root.token_popup_target = "team";
                                                root.token_popup_page = 0;
                                                root.show_token_popup = true;
                                            }
                                        }
                                    }
                                    if root.selected_team_kind == "folder" : Rectangle {
                                        width: 36px;
                                        height: 32px;
                                        background: transparent;
                                    }
                                    if root.selected_team_kind == "snippet" && !root.is_admin_edition : Rectangle {
                                        width: 36px;
                                        height: 32px;
                                        background: transparent;
                                    }
                                }
                            }
                            if root.selected_team_kind == "snippet" : HorizontalLayout {
                                spacing: 8px;
                                FieldLabel { text: ""; }
                                IconButton {
                                    btn-size: 32px;
                                    glyph: "\u{f0c5}"; glyph-weight: 400;
                                    tooltip-text: @tr("Copy snippet text");
                                    clicked => { root.copy_team_text(); }
                                    hover-changed(t) => { root.hover_tooltip_text = t; }
                                }
                                Text {
                                    text: root.is_admin_edition
                                        ? "Editing here updates the local Team tree. Use Publish to deploy to the share."
                                        : "Read-only: copy the text or assign a personal shortcut to its parent folder.";
                                    color: Theme.text-muted;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        if root.selected_team_kind == "snippet" : VerticalLayout {
                            spacing: 4px;
                            vertical-stretch: 1;
                            team-body-edit := ThemedTextEdit {
                                vertical-stretch: 1;
                                sync-from-external: true;
                                external-text: root.selected_team_text;
                                stamp: root.editor_sync_version;
                                font-family: Theme.ui-mono-font;
                                font-size: 13px;
                                read-only: !root.is_admin_edition;
                                wrap: word-wrap;
                                edited(t) => {
                                    if (root.is_admin_edition) { root.update_team_text(t); root.request_save(); }
                                }
                            }
                            TokenChipStrip { chips: root.team_tokens; }
                        }

                        if root.selected_team_kind == "folder" : VerticalLayout {
                            spacing: 8px;
                            vertical-stretch: 1;
                            Text {
                                text: root.is_admin_edition
                                    ? "Folders sync to the Team share when published. Per-user shortcut overrides are stored locally."
                                    : "Folders are managed by the team admin. You can still assign a personal shortcut here.";
                                color: Theme.text-dim;
                                font-size: 12px;
                                wrap: word-wrap;
                            }
                            Rectangle { vertical-stretch: 1; }
                        }

                        if root.selected_team_kind == "none" : Text {
                            text: @tr("Select a team folder or snippet on the left.");
                            color: Theme.text-muted;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                        }
                    }
                }
            }
        }

        Rectangle {
            background: Theme.bg-elev;
            height: 28px;
            border-color: Theme.border;
            border-width: 0;
            Rectangle {
                x: 0;
                y: 0;
                width: parent.width;
                height: 1px;
                background: Theme.border;
            }
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 12px;
                alignment: start;
                Text {
                    text: root.hover_tooltip_text != ""
                        ? root.hover_tooltip_text
                        : (root.editor_hint_text != "" ? root.editor_hint_text : root.status_text);
                    color: root.hover_tooltip_text != "" || root.editor_hint_text != ""
                        ? Theme.text
                        : Theme.text-dim;
                    font-size: 11px;
                    vertical-alignment: center;
                    overflow: elide;
                    horizontal-stretch: 1;
                }
                Rectangle {
                    width: 1px;
                    height: 16px;
                    background: Theme.border;
                    y: (parent.height - 16px) / 2;
                }
                Text {
                    text: root.team_share_status_text != "" ? "Share: " + root.team_share_status_text : "Share: —";
                    color: Theme.text-muted;
                    font-size: 11px;
                    vertical-alignment: center;
                }
                Rectangle {
                    width: 1px;
                    height: 16px;
                    background: Theme.border;
                    y: (parent.height - 16px) / 2;
                }
                Text {
                    text: root.deepl_status_text != "" ? "DeepL: " + root.deepl_status_text : "DeepL: not configured";
                    color: Theme.text-muted;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }
        }
    }

    if root.show_token_popup : Rectangle {
        background: transparent;
        TouchArea { clicked => { root.show_token_popup = false; } }

        Rectangle {
            x: max(8px, min(root.token_popup_x, parent.width - self.width - 8px));
            y: max(8px, min(root.token_popup_y, parent.height - self.height - 8px));
            width: 360px;
            height: 380px;
            background: Theme.bg-elev;
            border-color: Theme.border-strong;
            border-width: 1px;
            border-radius: Theme.radius-md;
            drop-shadow-blur: 18px;
            drop-shadow-color: Theme.is-light ? #00000033 : #00000099;
            TouchArea { clicked => { } }

            VerticalLayout {
                padding: 6px;
                spacing: 4px;

                Rectangle {
                    height: 28px;
                    background: transparent;
                    HorizontalLayout {
                        spacing: 6px;
                        alignment: stretch;
                        if root.token_popup_page != 0 : Rectangle {
                            width: 24px;
                            height: 24px;
                            border-radius: Theme.radius-sm;
                            background: back-ta.has-hover ? Theme.bg-hover : transparent;
                            FaGlyph {
                                glyph: "\u{f060}";
                                weight: 900;
                                glyph-size: 11px;
                                tint: Theme.text;
                                width: parent.width;
                                height: parent.height;
                            }
                            back-ta := TouchArea {
                                clicked => {
                                    root.token_popup_page = 0;
                                }
                            }
                        }
                        Text {
                            text: root.token_popup_page == 0 ? @tr("Insert token")
                                : root.token_popup_page == 1 ? @tr("Key / shortcut")
                                : root.token_popup_page == 2 ? @tr("Translate to...")
                                : root.token_popup_input_label;
                            color: Theme.text;
                            font-size: 14px;
                            font-weight: 700;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }
                }
                Rectangle { height: 1px; background: Theme.border; }

                if root.token_popup_page == 0 : ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 1px;
                        for entry in [
                            { label: @tr("Date  {{DATE}}"), token: "{DATE}", nav: 0, kind: "" },
                            { label: @tr("Enter  {{ENTER}}"), token: "{ENTER}", nav: 0, kind: "" },
                            { label: @tr("Tab  {{TAB}}"), token: "{TAB}", nav: 0, kind: "" },
                            { label: @tr("Clipboard  {{CLIPBOARD}}"), token: "{CLIPBOARD}", nav: 0, kind: "" },
                            { label: "—", token: "", nav: -1, kind: "" },
                            { label: @tr("Custom date..."), token: "", nav: 3, kind: "date" },
                            { label: @tr("Wait (ms)..."), token: "", nav: 3, kind: "wait" },
                            { label: "—", token: "", nav: -1, kind: "" },
                            { label: @tr("Context variable ({{VAR=name}})..."), token: "", nav: 3, kind: "var" },
                            { label: @tr("Database lookup ({{DATABASE=...}})..."), token: "", nav: 3, kind: "database" },
                            { label: @tr("Include another snippet ({{INCLUDE=name}})..."), token: "", nav: 3, kind: "include" },
                            { label: "—", token: "", nav: -1, kind: "" },
                            { label: @tr("Key / shortcut..."), token: "", nav: 1, kind: "" },
                            { label: @tr("Translate to..."), token: "", nav: 2, kind: "" },
                        ] : Rectangle {
                            height: entry.nav == -1 ? 7px : 32px;
                            border-radius: Theme.radius-sm;
                            background: entry.nav == -1
                                ? transparent
                                : (sep-ta.has-hover ? Theme.bg-hover : transparent);
                            if entry.nav == -1 : Rectangle {
                                x: 6px;
                                y: 3px;
                                width: parent.width - 12px;
                                height: 1px;
                                background: Theme.border;
                            }
                            if entry.nav != -1 : HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                Text {
                                    text: entry.label;
                                    color: Theme.text;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                                if entry.nav == 1 || entry.nav == 2 : FaGlyph {
                                    glyph: "\u{f054}";
                                    weight: 900;
                                    glyph-size: 10px;
                                    tint: Theme.text-muted;
                                    horizontal-alignment: right;
                                    vertical-alignment: center;
                                    width: 12px;
                                }
                            }
                            sep-ta := TouchArea {
                                enabled: entry.nav != -1;
                                clicked => {
                                    if (entry.nav == 0) {
                                        if (root.token_popup_target == "team") {
                                            root.insert_team_token(entry.token);
                                        } else {
                                            root.insert_personal_token(entry.token);
                                        }
                                        root.show_token_popup = false;
                                        root.request_save();
                                    } else if (entry.nav == 3) {
                                        root.token_popup_input_kind = entry.kind;
                                        if (entry.kind == "date") {
                                            root.token_popup_input_label = @tr("Custom date");
                                            root.token_popup_input_placeholder = "%d.%m.%Y %H:%M";
                                            root.token_popup_input_help = @tr("Python strftime format (e.g. %d.%m.%Y %H:%M).");
                                            root.token_popup_input_value = "%d.%m.%Y";
                                        } else if (entry.kind == "wait") {
                                            root.token_popup_input_label = @tr("Wait (ms)");
                                            root.token_popup_input_placeholder = "250";
                                            root.token_popup_input_help = @tr("Pause for how many milliseconds before continuing? (0–60000)");
                                            root.token_popup_input_value = "250";
                                        } else if (entry.kind == "var") {
                                            root.token_popup_input_label = @tr("Variable name");
                                            root.token_popup_input_placeholder = "country";
                                            root.token_popup_input_help = @tr("Names come from your context-extraction regexes (Options → Context).");
                                            root.token_popup_input_value = "";
                                        } else if (entry.kind == "database") {
                                            root.token_popup_input_label = @tr("Database lookup");
                                            root.token_popup_input_placeholder = "Sites,$region-$site,INET";
                                            root.token_popup_input_help = @tr("<DB>,<Lookup-key>,<Field>  — variables can be used as $name.");
                                            root.token_popup_input_value = "";
                                        } else if (entry.kind == "include") {
                                            root.token_popup_input_label = @tr("Include snippet");
                                            root.token_popup_input_placeholder = "Folder/Snippet name";
                                            root.token_popup_input_help = @tr("Inserts another snippet's body in place of {{INCLUDE=name}}.");
                                            root.token_popup_input_value = "";
                                        }
                                        root.token_popup_page = 3;
                                    } else {
                                        root.token_popup_page = entry.nav;
                                    }
                                }
                            }
                        }
                    }
                }

                if root.token_popup_page == 1 : ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 1px;
                        for entry in [
                            { label: @tr("Ctrl ({{CTRL}})"), token: "{CTRL}", custom: false },
                            { label: @tr("Alt ({{ALT}})"), token: "{ALT}", custom: false },
                            { label: @tr("Shift ({{SHIFT}})"), token: "{SHIFT}", custom: false },
                            { label: @tr("Delete ({{DEL}})"), token: "{DEL}", custom: false },
                            { label: @tr("Escape ({{ESC}})"), token: "{ESC}", custom: false },
                            { label: @tr("Backspace ({{BACKSPACE}})"), token: "{BACKSPACE}", custom: false },
                            { label: @tr("Space ({{SPACE}})"), token: "{SPACE}", custom: false },
                            { label: "—", token: "", custom: false },
                            { label: @tr("Select all (Ctrl+A)"), token: "{CTRL+A}", custom: false },
                            { label: @tr("Copy (Ctrl+C)"), token: "{CTRL+C}", custom: false },
                            { label: @tr("Cut (Ctrl+X)"), token: "{CTRL+X}", custom: false },
                            { label: @tr("Paste (Ctrl+V)"), token: "{CTRL+V}", custom: false },
                            { label: @tr("Undo (Ctrl+Z)"), token: "{CTRL+Z}", custom: false },
                            { label: @tr("Save (Ctrl+S)"), token: "{CTRL+S}", custom: false },
                            { label: @tr("Find (Ctrl+F)"), token: "{CTRL+F}", custom: false },
                            { label: @tr("Close window (Alt+F4)"), token: "{ALT+F4}", custom: false },
                            { label: @tr("Task switcher (Ctrl+Shift+Esc)"), token: "{CTRL+SHIFT+ESC}", custom: false },
                            { label: "—", token: "", custom: false },
                            { label: @tr("Custom key combo..."), token: "", custom: true },
                        ] : Rectangle {
                            height: entry.label == "—" ? 7px : 32px;
                            border-radius: Theme.radius-sm;
                            background: entry.label == "—"
                                ? transparent
                                : (key-ta.has-hover ? Theme.bg-hover : transparent);
                            if entry.label == "—" : Rectangle {
                                x: 6px;
                                y: 3px;
                                width: parent.width - 12px;
                                height: 1px;
                                background: Theme.border;
                            }
                            if entry.label != "—" : HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                Text {
                                    text: entry.label;
                                    color: Theme.text;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                            }
                            key-ta := TouchArea {
                                enabled: entry.label != "—";
                                clicked => {
                                    if (entry.custom) {
                                        root.token_popup_input_kind = "custom_key";
                                        root.token_popup_input_label = @tr("Custom key combo");
                                        root.token_popup_input_placeholder = "ctrl+shift+a";
                                        root.token_popup_input_help = @tr("Modifiers + a single key, e.g. ctrl+alt+f12. Stored as {{CTRL+ALT+F12}}.");
                                        root.token_popup_input_value = "";
                                        root.token_popup_page = 3;
                                    } else {
                                        if (root.token_popup_target == "team") {
                                            root.insert_team_token(entry.token);
                                        } else {
                                            root.insert_personal_token(entry.token);
                                        }
                                        root.show_token_popup = false;
                                        root.request_save();
                                    }
                                }
                            }
                        }
                    }
                }

                if root.token_popup_page == 2 : ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 1px;
                        for entry in [
                            { label: @tr("English (US) (EN-US)"), code: "EN-US", custom: false },
                            { label: @tr("English (UK) (EN-GB)"), code: "EN-GB", custom: false },
                            { label: @tr("German (DE)"), code: "DE", custom: false },
                            { label: @tr("French (FR)"), code: "FR", custom: false },
                            { label: @tr("Spanish (ES)"), code: "ES", custom: false },
                            { label: @tr("Italian (IT)"), code: "IT", custom: false },
                            { label: @tr("Dutch (NL)"), code: "NL", custom: false },
                            { label: @tr("Portuguese (PT-PT)"), code: "PT-PT", custom: false },
                            { label: @tr("Portuguese (Brazil) (PT-BR)"), code: "PT-BR", custom: false },
                            { label: @tr("Polish (PL)"), code: "PL", custom: false },
                            { label: @tr("Russian (RU)"), code: "RU", custom: false },
                            { label: @tr("Japanese (JA)"), code: "JA", custom: false },
                            { label: @tr("Chinese (ZH)"), code: "ZH", custom: false },
                            { label: "—", code: "", custom: false },
                            { label: @tr("Other target language..."), code: "", custom: true },
                            { label: @tr("Translate from specific language..."), code: "PAIR", custom: false },
                        ] : Rectangle {
                            height: entry.label == "—" ? 7px : 32px;
                            border-radius: Theme.radius-sm;
                            background: entry.label == "—"
                                ? transparent
                                : (tr-ta.has-hover ? Theme.bg-hover : transparent);
                            if entry.label == "—" : Rectangle {
                                x: 6px;
                                y: 3px;
                                width: parent.width - 12px;
                                height: 1px;
                                background: Theme.border;
                            }
                            if entry.label != "—" : HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                Text {
                                    text: entry.label;
                                    color: Theme.text;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                            }
                            tr-ta := TouchArea {
                                enabled: entry.label != "—";
                                clicked => {
                                    if (entry.custom) {
                                        root.token_popup_input_kind = "custom_translation";
                                        root.token_popup_input_label = @tr("Translate to...");
                                        root.token_popup_input_placeholder = "EN-US";
                                        root.token_popup_input_help = @tr("DeepL target code (e.g. EN-US, FR, PT-BR). Inserted as {{TRANSLATION=...}}{{TRANSLATION_END}}.");
                                        root.token_popup_input_value = "";
                                        root.token_popup_page = 3;
                                    } else if (entry.code == "PAIR") {
                                        root.translation_picker_target = root.token_popup_target;
                                        root.show_token_popup = false;
                                        root.show_translation_picker = true;
                                    } else {
                                        if (root.token_popup_target == "team") {
                                            root.insert_team_token("{TRANSLATION=" + entry.code + "}{TRANSLATION_END}");
                                        } else {
                                            root.insert_personal_token("{TRANSLATION=" + entry.code + "}{TRANSLATION_END}");
                                        }
                                        root.show_token_popup = false;
                                        root.request_save();
                                    }
                                }
                            }
                        }
                    }
                }

                if root.token_popup_page == 3 : VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 8px;
                    padding-left: 10px;
                    padding-right: 10px;
                    padding-top: 6px;
                    Text {
                        text: root.token_popup_input_help;
                        color: Theme.text-dim;
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                    LabeledLineEdit {
                        value <=> root.token_popup_input_value;
                        placeholder: root.token_popup_input_placeholder;
                        accepted(t) => {
                            root.build_and_insert_token(
                                root.token_popup_target,
                                root.token_popup_input_kind,
                                t,
                            );
                            root.show_token_popup = false;
                            root.request_save();
                        }
                    }
                    HorizontalLayout {
                        spacing: 6px;
                        alignment: end;
                        Button {
                            text: @tr("Cancel");
                            clicked => { root.token_popup_page = 0; }
                        }
                        Button {
                            text: @tr("Insert");
                            clicked => {
                                root.build_and_insert_token(
                                    root.token_popup_target,
                                    root.token_popup_input_kind,
                                    root.token_popup_input_value,
                                );
                                root.show_token_popup = false;
                                root.request_save();
                            }
                        }
                    }
                    Rectangle { vertical-stretch: 1; }
                }
            }
        }
    }

    if root.show_personal_hotkey_popup : Rectangle {
        background: transparent;
        TouchArea {
            clicked => {
                root.show_personal_hotkey_popup = false;
            }
        }
        Rectangle {
            x: max(8px, min(root.personal_hotkey_popup_x, parent.width - self.width - 8px));
            y: max(8px, min(root.personal_hotkey_popup_y, parent.height - self.height - 8px));
            width: 320px;
            height: 52px;
            background: Theme.bg-elev;
            border-color: Theme.border-strong;
            border-width: 1px;
            border-radius: Theme.radius-md;
            drop-shadow-blur: 18px;
            drop-shadow-color: Theme.is-light ? #00000033 : #00000099;
            TouchArea { clicked => { } }
            HotkeyCapture {
                x: 8px;
                y: 8px;
                width: parent.width - 16px;
                height: parent.height - 16px;
                hotkey-text: root.selected_personal_shortcut;
                placeholder: @tr("Press keys (Esc to clear)");
                key-captured(text, c, a, s, m) => {
                    root.update_personal_shortcut(root.format_hotkey(text, c, a, s, m));
                    root.show_personal_hotkey_popup = false;
                    root.request_save();
                }
                cleared => {
                    root.update_personal_shortcut("");
                    root.show_personal_hotkey_popup = false;
                    root.request_save();
                }
            }
        }
    }

    if root.show_team_hotkey_popup : Rectangle {
        background: transparent;
        TouchArea {
            clicked => {
                root.show_team_hotkey_popup = false;
            }
        }
        Rectangle {
            x: max(8px, min(root.team_hotkey_popup_x, parent.width - self.width - 8px));
            y: max(8px, min(root.team_hotkey_popup_y, parent.height - self.height - 8px));
            width: 320px;
            height: 52px;
            background: Theme.bg-elev;
            border-color: Theme.border-strong;
            border-width: 1px;
            border-radius: Theme.radius-md;
            drop-shadow-blur: 18px;
            drop-shadow-color: Theme.is-light ? #00000033 : #00000099;
            TouchArea { clicked => { } }
            HotkeyCapture {
                x: 8px;
                y: 8px;
                width: parent.width - 16px;
                height: parent.height - 16px;
                hotkey-text: root.selected_team_shortcut;
                placeholder: @tr("Press keys (Esc to clear)");
                key-captured(text, c, a, s, m) => {
                    root.update_team_shortcut(root.format_hotkey(text, c, a, s, m));
                    root.show_team_hotkey_popup = false;
                    root.request_save();
                }
                cleared => {
                    root.update_team_shortcut("");
                    root.show_team_hotkey_popup = false;
                    root.request_save();
                }
            }
        }
    }

    if root.help_visible : Rectangle {
        background: transparent;
        TouchArea { clicked => { root.help_visible = false; } }

        Rectangle {
            x: max(8px, min(root.help_anchor_x, parent.width - self.width - 8px));
            y: max(8px, min(root.help_anchor_y, parent.height - self.height - 8px));
            width: 340px;
            height: help-text-elem.preferred-height + 28px;
            background: Theme.bg-elev;
            border-color: Theme.border-strong;
            border-width: 1px;
            border-radius: Theme.radius-md;
            drop-shadow-blur: 18px;
            drop-shadow-color: Theme.is-light ? #00000033 : #00000099;
            TouchArea { clicked => { } }
            help-text-elem := Text {
                x: 14px;
                y: 14px;
                width: parent.width - 28px;
                text: root.help_text;
                color: Theme.text;
                font-size: 12px;
                wrap: word-wrap;
            }
        }
    }

    if root.show_options_panel : Rectangle {
        background: Theme.is-light ? #00000033 : #0000007a;
        TouchArea { clicked => { root.show_options_panel = false; } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(720px, parent.width - 80px);
            height: min(640px, parent.height - 80px);
            background: Theme.bg-elev;
            border-color: Theme.border-strong;
            border-width: 1px;
            border-radius: Theme.radius-md;
            drop-shadow-blur: 30px;
            drop-shadow-color: #00000080;
            TouchArea { clicked => { } }

            VerticalLayout {
                padding: 0;
                spacing: 0;

                Rectangle {
                    height: 44px;
                    HorizontalLayout {
                        padding-left: 18px;
                        padding-right: 8px;
                        spacing: 10px;
                        alignment: start;
                        FaGlyph {
                            glyph: "\u{f013}"; weight: 900; glyph-size: 14px;
                            tint: Theme.text;
                            width: 18px;
                        }
                        Text {
                            text: @tr("Options");
                            color: Theme.text;
                            font-size: 14px;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }
                    Rectangle {
                        x: 0;
                        y: parent.height - 1px;
                        width: parent.width;
                        height: 1px;
                        background: Theme.border;
                    }
                }

                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    padding-top: 8px;
                    padding-bottom: 0;
                    spacing: 4px;
                    OptionsTabButton {
                        tab-label: @tr("GENERAL");
                        tab-selected: root.options_tab_index == 0;
                        tab-clicked => {
                            root.options_tab_index = 0;
                        }
                    }
                    OptionsTabButton {
                        tab-label: @tr("TEAM SHARE");
                        tab-selected: root.options_tab_index == 1;
                        tab-clicked => {
                            root.options_tab_index = 1;
                        }
                    }
                    OptionsTabButton {
                        tab-label: @tr("TRANSLATION (DEEPL)");
                        tab-selected: root.options_tab_index == 2;
                        tab-clicked => {
                            root.options_tab_index = 2;
                        }
                    }
                    OptionsTabButton {
                        tab-label: @tr("CONTEXT EXTRACTION");
                        tab-selected: root.options_tab_index == 3;
                        tab-clicked => {
                            root.options_tab_index = 3;
                        }
                    }
                }
                Rectangle {
                    height: 1px;
                    background: Theme.border;
                }

                ScrollView {
                    vertical-stretch: 1;
                    options-form := VerticalLayout {
                        padding-left: 22px;
                        padding-right: 22px;
                        padding-top: 18px;
                        padding-bottom: 18px;
                        spacing: 18px;

                        if root.options_tab_index == 0 : VerticalLayout {
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 8px;
                                OptionsFieldLabel { text: @tr("Hotkey"); }
                                HotkeyCapture {
                                    hotkey-text: root.hotkey_text;
                                    placeholder: "Click and press a key combo (Esc to clear)";
                                    horizontal-stretch: 1;
                                    key-captured(text, c, a, s, m) => {
                                        root.hotkey_text = root.format_hotkey(text, c, a, s, m);
                                    }
                                    cleared => { root.hotkey_text = ""; }
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                OptionsFieldLabel { text: @tr("Date format"); }
                                LabeledLineEdit {
                                    value <=> root.date_format_text;
                                    placeholder: "%d/%m/%Y";
                                    horizontal-stretch: 1;
                                    edited(t) => { root.date_format_edited(t); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                OptionsFieldLabel { text: @tr("Preview"); }
                                Text {
                                    text: root.date_format_preview_text;
                                    color: Theme.text-dim;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-alignment: left;
                                    horizontal-stretch: 1;
                                    height: 24px;
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                OptionsFieldLabel { text: @tr("Default mode"); }
                                ThemedComboBox {
                                    model: [@tr("Clipboard (Ctrl+V)"), @tr("Clipboard (Shift+Ins)"), @tr("Typing (key events)"), @tr("Typing (web compat)")];
                                    current-index <=> root.default_injection_index;
                                    horizontal-stretch: 1;
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                OptionsFieldLabel { text: @tr("Theme & accent"); }
                                HorizontalLayout {
                                    spacing: 10px;
                                    horizontal-stretch: 1;
                                    ThemedComboBox {
                                        model: [@tr("Auto"), @tr("Light"), @tr("Dark")];
                                        current-index <=> root.theme_index;
                                        horizontal-stretch: 1;
                                    }
                                    Rectangle {
                                        width: 40px;
                                        height: 32px;
                                        border-radius: Theme.radius-sm;
                                        border-width: 1px;
                                        border-color: Theme.border;
                                        background: opt-accent-ta.has-hover
                                            ? Theme.bg-hover
                                            : Theme.bg-input;
                                        Rectangle {
                                            x: (parent.width - 20px) / 2;
                                            y: (parent.height - 20px) / 2;
                                            width: 20px;
                                            height: 20px;
                                            border-radius: 4px;
                                            border-width: 1px;
                                            border-color: Theme.border-strong;
                                            background: root.options_accent_preview;
                                        }
                                        opt-accent-ta := TouchArea {
                                            clicked => {
                                                root.color_popup_target = "accent";
                                                root.color_popup_x =
                                                    self.absolute-position.x
                                                    + (self.width - 216px) / 2;
                                                root.color_popup_y =
                                                    self.absolute-position.y + self.height + 4px;
                                                root.show_color_popup = true;
                                            }
                                        }
                                    }
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                OptionsFieldLabel { text: @tr("Language"); }
                                language-combo := ThemedComboBox {
                                    model: root.available_languages;
                                    current-index <=> root.language_index;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        if root.options_tab_index == 1 : VerticalLayout {
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 8px;
                                OptionsFieldLabel { text: @tr("Share path"); }
                                LabeledLineEdit {
                                    value <=> root.team_share_text;
                                    placeholder: "\\\\server\\share\\poltergeist  |  https://…/folder/";
                                    horizontal-stretch: 1;
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                OptionsFieldLabel { text: ""; }
                                Rectangle {
                                    width: 10px;
                                    height: 10px;
                                    border-radius: 5px;
                                    y: (parent.height - 10px) / 2;
                                    background: root.team_share_status_kind == 1 ? Theme.success
                                              : root.team_share_status_kind == 2 ? Theme.warning
                                              : root.team_share_status_kind == 3 ? Theme.danger
                                              : Theme.text-muted;
                                }
                                if root.team_share_status_kind != 0 : FaGlyph {
                                    glyph: root.team_share_status_kind == 1 ? "\u{f233}"
                                         : root.team_share_status_kind == 2 ? "\u{f0c7}"
                                         : root.team_share_status_kind == 3 ? "\u{f057}"
                                         : "";
                                    glyph-size: 14px;
                                    weight: 900;
                                    tint: root.team_share_status_kind == 1 ? Theme.success
                                        : root.team_share_status_kind == 2 ? Theme.warning
                                        : root.team_share_status_kind == 3 ? Theme.danger
                                        : Theme.text-dim;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: 18px;
                                    height: 18px;
                                }
                                Text {
                                    text: root.team_share_status_text != ""
                                        ? root.team_share_status_text
                                        : @tr("No share configured");
                                    color: Theme.text-dim;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        if root.options_tab_index == 2 : VerticalLayout {
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 8px;
                                OptionsFieldLabel { text: @tr("API key"); }
                                LabeledLineEdit {
                                    value <=> root.deepl_api_key_text;
                                    placeholder: @tr("DeepL API key");
                                    password: !root.deepl_key_visible;
                                    horizontal-stretch: 1;
                                    edited(t) => { root.deepl_key_edited(t); }
                                }
                                Rectangle {
                                    width: 64px;
                                    height: 32px;
                                    border-radius: Theme.radius-sm;
                                    background: deepl-show-ta.has-hover ? Theme.bg-active : Theme.bg-input;
                                    border-color: Theme.border;
                                    border-width: 1px;
                                    Text {
                                        text: root.deepl_key_visible ? @tr("Hide") : @tr("Show");
                                        color: Theme.text;
                                        font-size: 12px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: parent.width;
                                        height: parent.height;
                                    }
                                    deepl-show-ta := TouchArea {
                                        clicked => {
                                            root.deepl_key_visible = !root.deepl_key_visible;
                                        }
                                    }
                                }
                                Rectangle {
                                    width: 88px;
                                    height: 32px;
                                    border-radius: Theme.radius-sm;
                                    background: deepl-validate-ta.has-hover ? Theme.bg-active : Theme.bg-input;
                                    border-color: Theme.border;
                                    border-width: 1px;
                                    Text {
                                        text: @tr("Validate");
                                        color: Theme.text;
                                        font-size: 12px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: parent.width;
                                        height: parent.height;
                                    }
                                    deepl-validate-ta := TouchArea {
                                        clicked => { root.validate_deepl_key(); }
                                    }
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                OptionsFieldLabel { text: ""; }
                                Rectangle {
                                    width: 10px;
                                    height: 10px;
                                    border-radius: 5px;
                                    y: (parent.height - 10px) / 2;
                                    background: root.deepl_status_kind == 1 ? Theme.success
                                              : root.deepl_status_kind == 2 ? Theme.danger
                                              : Theme.text-muted;
                                }
                                Text {
                                    text: root.deepl_status_text != ""
                                        ? root.deepl_status_text
                                        : @tr("Not configured");
                                    color: Theme.text-dim;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        if root.options_tab_index == 3 : VerticalLayout {
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 8px;
                                OptionsFieldLabel {
                                    text: @tr("Patterns");
                                    vertical-alignment: top;
                                }
                                ThemedTextEdit {
                                    horizontal-stretch: 1;
                                    height: 140px;
                                    sync-from-external: false;
                                    text <=> root.context_patterns_text;
                                    font-family: Theme.ui-mono-font;
                                    font-size: 12px;
                                    wrap: word-wrap;
                                    placeholder-text: @tr("regex1\nregex2 with named groups\n…");
                                }
                            }
                            Text {
                                text: @tr("Patterns are applied to clipboard text before showing the popup. Named groups become {{VAR=name}} variables.");
                                color: Theme.text-muted;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                Rectangle {
                    height: 56px;
                    Rectangle {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: 1px;
                        background: Theme.border;
                    }
                    HorizontalLayout {
                        padding-left: 18px;
                        padding-right: 18px;
                        padding-top: 12px;
                        padding-bottom: 12px;
                        spacing: 8px;
                        alignment: end;
                        Rectangle {
                            width: 96px;
                            height: 36px;
                            border-radius: Theme.radius-sm;
                            background: cancel-ta.has-hover ? Theme.bg-active : Theme.bg-input;
                            border-color: Theme.border;
                            border-width: 1px;
                            Text {
                                text: @tr("Cancel");
                                color: Theme.text;
                                font-size: 16px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                            cancel-ta := TouchArea {
                                clicked => { root.show_options_panel = false; }
                            }
                        }
                        Rectangle {
                            width: 114px;
                            height: 36px;
                            border-radius: Theme.radius-sm;
                            background: apply-ta.has-hover ? Theme.accent-hover : Theme.accent;
                            Text {
                                text: @tr("Apply");
                                color: white;
                                font-size: 16px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                            apply-ta := TouchArea {
                                clicked => {
                                    root.apply_settings(
                                        root.hotkey_text,
                                        root.date_format_text,
                                        root.default_injection_index,
                                        root.team_share_text,
                                        root.context_patterns_text,
                                        root.theme_index,
                                        root.language_index,
                                        root.deepl_api_key_text,
                                        root.start_with_windows,
                                        root.options_accent_hex,
                                    );
                                    root.show_options_panel = false;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if root.show_about_panel : Rectangle {
        background: Theme.is-light ? #00000033 : #0000007a;
        TouchArea { clicked => { root.show_about_panel = false; } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(520px, parent.width - 80px);
            height: min(440px, parent.height - 80px);
            background: Theme.bg-elev;
            border-color: Theme.border-strong;
            border-width: 1px;
            border-radius: Theme.radius-md;
            drop-shadow-blur: 30px;
            drop-shadow-color: #00000080;
            TouchArea { clicked => { } }

            VerticalLayout {
                padding: 18px;
                spacing: 10px;
                alignment: start;

                HorizontalLayout {
                    spacing: 14px;
                    alignment: start;
                    Image {
                        source: root.is_admin_edition
                            ? @image-url("../../../assets/AppIconAdmin.png")
                            : @image-url("../../../assets/AppIcon.png");
                        width: 72px;
                        height: 72px;
                    }
                    VerticalLayout {
                        spacing: 2px;
                        alignment: center;
                        horizontal-stretch: 1;
                        Text {
                            text: root.is_admin_edition ? @tr("Poltergeist [ADMIN]") : @tr("Poltergeist");
                            color: Theme.text;
                            font-size: 20px;
                            font-weight: 800;
                        }
                        Text {
                            text: @tr("Version {0}", root.app_version_text);
                            color: Theme.text-muted;
                            font-size: 12px;
                        }
                    }
                }

                Text {
                    text: @tr("Copyright © 2026 Lutz Schwemer Panchez. All rights reserved.");
                    color: Theme.text-dim;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    alignment: start;
                    Rectangle {
                        width: gh-text.preferred-width + 42px;
                        height: 30px;
                        border-radius: Theme.radius-sm;
                        background: gh-ta.has-hover ? Theme.bg-hover : Theme.bg-input;
                        border-color: Theme.border;
                        border-width: 1px;
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 8px;
                            alignment: center;
                            FaGlyph {
                                glyph: "\u{f09b}";
                                is-brands: true;
                                weight: 400;
                                glyph-size: 14px;
                                tint: Theme.text;
                                width: 16px;
                            }
                            gh-text := Text {
                                text: @tr("GitHub: iShark5060");
                                color: Theme.text;
                                font-size: 12px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                        gh-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.open_github(); }
                        }
                    }
                }

                Rectangle { height: 1px; background: Theme.border; }
                Text {
                    text: @tr("Icon credits");
                    color: Theme.text;
                    font-size: 14px;
                    font-weight: 700;
                }
                Text {
                    text: @tr("Application icons created with assets from:\nPixel perfect - Flaticon");
                    color: Theme.text-dim;
                    font-size: 14px;
                    wrap: word-wrap;
                }
                flaticon-link-row := HorizontalLayout {
                    spacing: 0;
                    alignment: start;
                    Rectangle {
                        width: flaticon-link-text.preferred-width + 4px;
                        height: flaticon-link-text.preferred-height + 2px;
                        background: transparent;
                        flaticon-link-text := Text {
                            text: @tr("https://www.flaticon.com/");
                            color: flaticon-link-ta.has-hover ? Theme.accent-hover : Theme.accent;
                            font-size: 14px;
                            font-weight: 600;
                        }
                        Rectangle {
                            x: 0;
                            y: parent.height - 1px;
                            width: flaticon-link-text.preferred-width;
                            height: 1px;
                            background: flaticon-link-ta.has-hover ? Theme.accent-hover : Theme.accent;
                        }
                        flaticon-link-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.open_url("https://www.flaticon.com/");
                            }
                        }
                    }
                }
                Text {
                    text: @tr("UI icons by:\nFont Awesome 7 Free (Solid + Regular)\nFont Awesome 7 Brands");
                    color: Theme.text-dim;
                    font-size: 14px;
                    wrap: word-wrap;
                }
                fa-link-row := HorizontalLayout {
                    spacing: 0;
                    alignment: start;
                    Rectangle {
                        width: fa-link-text.preferred-width + 4px;
                        height: fa-link-text.preferred-height + 2px;
                        background: transparent;
                        fa-link-text := Text {
                            text: @tr("https://fontawesome.com/");
                            color: fa-link-ta.has-hover ? Theme.accent-hover : Theme.accent;
                            font-size: 14px;
                            font-weight: 600;
                        }
                        Rectangle {
                            x: 0;
                            y: parent.height - 1px;
                            width: fa-link-text.preferred-width;
                            height: 1px;
                            background: fa-link-ta.has-hover ? Theme.accent-hover : Theme.accent;
                        }
                        fa-link-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.open_url("https://fontawesome.com/");
                            }
                        }
                    }
                }

                HorizontalLayout {
                    alignment: end;
                    Rectangle {
                        width: 110px;
                        height: 32px;
                        border-radius: Theme.radius-sm;
                        background: about-ok-ta.has-hover ? Theme.accent-hover : Theme.accent;
                        Text {
                            text: @tr("Close");
                            color: white;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        about-ok-ta := TouchArea {
                            clicked => { root.show_about_panel = false; }
                        }
                    }
                }
            }
        }
    }

    if root.show_review_panel : Rectangle {
        background: Theme.is-light ? #00000033 : #0000007a;
        TouchArea { clicked => { /* swallow */ } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 620px;
            height: 460px;
            background: Theme.bg-elev;
            border-color: Theme.border-strong;
            border-width: 1px;
            border-radius: Theme.radius-md;
            drop-shadow-blur: 30px;
            drop-shadow-color: #00000080;
            TouchArea { clicked => { } }

            VerticalLayout {
                padding: 22px;
                spacing: 12px;
                alignment: start;

                Text {
                    text: @tr("Review text before paste");
                    color: Theme.text;
                    font-size: 16px;
                    font-weight: 700;
                }
                Text {
                    text: @tr("Review and edit the untranslated text before it is pasted. Cancel will stop this snippet completely.");
                    color: Theme.text-dim;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                review-edit := ThemedTextEdit {
                    vertical-stretch: 1;
                    sync-from-external: false;
                    text <=> root.review_text;
                    font-family: Theme.ui-font;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    Rectangle {
                        width: 110px;
                        height: 32px;
                        border-radius: Theme.radius-sm;
                        background: review-cancel-ta.has-hover ? Theme.bg-hover : Theme.bg-input;
                        border-color: Theme.border;
                        border-width: 1px;
                        Text {
                            text: @tr("Cancel");
                            color: Theme.text;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        review-cancel-ta := TouchArea {
                            clicked => {
                                root.show_review_panel = false;
                                root.cancel_review();
                            }
                        }
                    }
                    Rectangle {
                        width: 110px;
                        height: 32px;
                        border-radius: Theme.radius-sm;
                        background: review-ok-ta.has-hover ? Theme.accent-hover : Theme.accent;
                        Text {
                            text: @tr("OK");
                            color: white;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        review-ok-ta := TouchArea {
                            clicked => {
                                root.show_review_panel = false;
                                root.confirm_review(review-edit.text);
                            }
                        }
                    }
                }
            }
        }
    }

    if root.show_picker_panel : Rectangle {
        background: Theme.is-light ? #00000033 : #0000007a;
        TouchArea { clicked => { /* swallow */ } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 560px;
            height: 600px;
            background: Theme.bg-elev;
            border-color: Theme.border-strong;
            border-width: 1px;
            border-radius: Theme.radius-md;
            drop-shadow-blur: 30px;
            drop-shadow-color: #00000080;
            TouchArea { clicked => { } }

            VerticalLayout {
                padding: 22px;
                spacing: 12px;
                alignment: start;

                Text {
                    text: root.picker_title;
                    color: Theme.text;
                    font-size: 16px;
                    font-weight: 700;
                }
                if root.picker_subtitle != "" : Text {
                    text: root.picker_subtitle;
                    color: Theme.text-dim;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                Rectangle {
                    background: Theme.bg-input;
                    border-width: 0;
                    border-radius: Theme.radius-sm;
                    vertical-stretch: 1;

                    ScrollView {
                        x: 4px;
                        y: 4px;
                        width: parent.width - 8px;
                        height: parent.height - 8px;
                        VerticalLayout {
                            spacing: 1px;
                            for row[i] in root.picker_rows : Rectangle {
                                height: 26px;
                                background: picker-row-ta.has-hover ? Theme.bg-hover : transparent;
                                border-radius: Theme.radius-sm;

                                HorizontalLayout {
                                    x: 4px + (row.depth * 18px);
                                    width: parent.width - (4px + (row.depth * 18px));
                                    height: parent.height;
                                    spacing: 6px;
                                    alignment: start;

                                    Rectangle {
                                        width: 14px;
                                        height: parent.height;
                                        if row.is-folder && row.has-children : FaGlyph {
                                            glyph: row.expanded ? "\u{f078}" : "\u{f054}";
                                            glyph-size: 9px;
                                            tint: Theme.text-dim;
                                            x: 0; y: 0;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                        if row.is-folder && row.has-children : TouchArea {
                                            clicked => { root.picker_toggle_expand(i); }
                                        }
                                    }

                                    Rectangle {
                                        width: 16px;
                                        height: 16px;
                                        y: (parent.height - self.height) / 2;
                                        border-radius: 3px;
                                        border-width: 1px;
                                        border-color: row.check-state == 0
                                            ? Theme.border-strong : Theme.accent;
                                        background: row.check-state == 0
                                            ? Theme.bg-input : Theme.accent;
                                        if row.check-state == 1 : FaGlyph {
                                            glyph: "\u{f00c}";
                                            glyph-size: 9px;
                                            tint: white;
                                            x: 0; y: 0;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                        if row.check-state == 2 : Rectangle {
                                            background: white;
                                            width: 8px;
                                            height: 2px;
                                            x: (parent.width - self.width) / 2;
                                            y: (parent.height - self.height) / 2;
                                        }
                                        TouchArea { clicked => { root.picker_toggle_check(i); } }
                                    }

                                    Rectangle {
                                        width: 16px;
                                        height: 16px;
                                        y: (parent.height - self.height) / 2;
                                        FaGlyph {
                                            glyph: row.is-folder
                                                ? "\u{f07c}"
                                                : (row.inject-kbd ? "\u{f11c}" : "\u{f328}");
                                            glyph-size: 12px;
                                            tint: Theme.text-dim;
                                            x: 0; y: 0;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                    }

                                    Text {
                                        text: row.text;
                                        color: Theme.text;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }
                                }
                                picker-row-ta := TouchArea {
                                    clicked => { root.picker_toggle_check(i); }
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 6px;
                    alignment: start;
                    Rectangle {
                        width: 110px;
                        height: 30px;
                        border-radius: Theme.radius-sm;
                        background: pk-all-ta.has-hover ? Theme.bg-hover : Theme.bg-input;
                        border-color: Theme.border;
                        border-width: 1px;
                        Text {
                            text: @tr("Select all");
                            color: Theme.text;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        pk-all-ta := TouchArea { clicked => { root.picker_select_all(); } }
                    }
                    Rectangle {
                        width: 110px;
                        height: 30px;
                        border-radius: Theme.radius-sm;
                        background: pk-none-ta.has-hover ? Theme.bg-hover : Theme.bg-input;
                        border-color: Theme.border;
                        border-width: 1px;
                        Text {
                            text: @tr("Deselect all");
                            color: Theme.text;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        pk-none-ta := TouchArea { clicked => { root.picker_clear_all(); } }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Text {
                        text: root.picker_summary;
                        color: Theme.text-dim;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }

                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    Rectangle {
                        width: 110px;
                        height: 32px;
                        border-radius: Theme.radius-sm;
                        background: pk-cancel-ta.has-hover ? Theme.bg-hover : Theme.bg-input;
                        border-color: Theme.border;
                        border-width: 1px;
                        Text {
                            text: @tr("Cancel");
                            color: Theme.text;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        pk-cancel-ta := TouchArea {
                            clicked => {
                                root.show_picker_panel = false;
                                root.picker_cancel();
                            }
                        }
                    }
                    Rectangle {
                        width: 130px;
                        height: 32px;
                        border-radius: Theme.radius-sm;
                        background: !root.picker_can_accept ? Theme.bg-input
                            : (pk-ok-ta.has-hover ? Theme.accent-hover : Theme.accent);
                        border-color: Theme.border;
                        border-width: !root.picker_can_accept ? 1px : 0;
                        Text {
                            text: root.picker_ok_label;
                            color: !root.picker_can_accept ? Theme.text-muted : white;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        pk-ok-ta := TouchArea {
                            enabled: root.picker_can_accept;
                            clicked => {
                                root.show_picker_panel = false;
                                root.picker_accept();
                            }
                        }
                    }
                }
            }
        }
    }

    if root.show_confirm_panel : Rectangle {
        background: Theme.is-light ? #00000033 : #0000007a;
        TouchArea { clicked => { /* swallow */ } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 480px;
            height: self.preferred-height;
            background: Theme.bg-elev;
            border-color: Theme.border-strong;
            border-width: 1px;
            border-radius: Theme.radius-md;
            drop-shadow-blur: 30px;
            drop-shadow-color: #00000080;
            TouchArea { clicked => { } }

            VerticalLayout {
                padding: 22px;
                spacing: 12px;
                alignment: start;
                Text {
                    text: root.confirm_title;
                    color: Theme.text;
                    font-size: 16px;
                    font-weight: 700;
                }
                Text {
                    text: root.confirm_message;
                    color: Theme.text-dim;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    if root.confirm_show_cancel : Rectangle {
                        width: 110px;
                        height: 32px;
                        border-radius: Theme.radius-sm;
                        background: cf-cancel-ta.has-hover ? Theme.bg-hover : Theme.bg-input;
                        border-color: Theme.border;
                        border-width: 1px;
                        Text {
                            text: root.confirm_cancel_label;
                            color: Theme.text;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        cf-cancel-ta := TouchArea {
                            clicked => {
                                root.show_confirm_panel = false;
                                root.confirm_cancel(root.confirm_kind);
                            }
                        }
                    }
                    if root.confirm_show_no : Rectangle {
                        width: 130px;
                        height: 32px;
                        border-radius: Theme.radius-sm;
                        background: cf-no-ta.has-hover ? Theme.bg-hover : Theme.bg-input;
                        border-color: Theme.border;
                        border-width: 1px;
                        Text {
                            text: root.confirm_no_label;
                            color: Theme.text;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        cf-no-ta := TouchArea {
                            clicked => {
                                root.show_confirm_panel = false;
                                root.confirm_no(root.confirm_kind);
                            }
                        }
                    }
                    Rectangle {
                        width: 130px;
                        height: 32px;
                        border-radius: Theme.radius-sm;
                        background: cf-yes-ta.has-hover ? Theme.accent-hover : Theme.accent;
                        Text {
                            text: root.confirm_yes_label;
                            color: white;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        cf-yes-ta := TouchArea {
                            clicked => {
                                root.show_confirm_panel = false;
                                root.confirm_yes(root.confirm_kind);
                            }
                        }
                    }
                }
            }
        }
    }

    if root.show_translation_picker : Rectangle {
        background: Theme.is-light ? #00000033 : #0000007a;
        TouchArea { clicked => { /* swallow */ } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 420px;
            height: 290px;
            background: Theme.bg-elev;
            border-color: Theme.border-strong;
            border-width: 1px;
            border-radius: Theme.radius-md;
            drop-shadow-blur: 30px;
            drop-shadow-color: #00000080;
            TouchArea { clicked => { } }

            VerticalLayout {
                padding: 22px;
                spacing: 12px;
                alignment: start;

                Text {
                    text: @tr("Insert translation");
                    color: Theme.text;
                    font-size: 16px;
                    font-weight: 700;
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: @tr("Source language:");
                        color: Theme.text;
                        font-size: 14px;
                        vertical-alignment: center;
                        width: 130px;
                    }
                    tr-src-combo := ThemedComboBox {
                        horizontal-stretch: 1;
                        model: root.translation_source_options;
                        current-index <=> root.translation_source_index;
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: @tr("Target language:");
                        color: Theme.text;
                        font-size: 14px;
                        vertical-alignment: center;
                        width: 130px;
                    }
                    tr-tgt-combo := ThemedComboBox {
                        horizontal-stretch: 1;
                        model: root.translation_target_options;
                        current-index <=> root.translation_target_index;
                    }
                }
                Text {
                    text: @tr("Leave the source on Auto-detect unless you need to force it (e.g. short ambiguous phrases).");
                    color: Theme.text-dim;
                    font-size: 11px;
                    wrap: word-wrap;
                }

                Rectangle { vertical-stretch: 1; }

                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    Rectangle {
                        width: 110px;
                        height: 32px;
                        border-radius: Theme.radius-sm;
                        background: tr-cancel-ta.has-hover ? Theme.bg-hover : Theme.bg-input;
                        border-color: Theme.border;
                        border-width: 1px;
                        Text {
                            text: @tr("Cancel");
                            color: Theme.text;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        tr-cancel-ta := TouchArea {
                            clicked => { root.show_translation_picker = false; }
                        }
                    }
                    Rectangle {
                        width: 110px;
                        height: 32px;
                        border-radius: Theme.radius-sm;
                        background: tr-ok-ta.has-hover ? Theme.accent-hover : Theme.accent;
                        Text {
                            text: @tr("Insert");
                            color: white;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        tr-ok-ta := TouchArea {
                            clicked => {
                                root.show_translation_picker = false;
                                root.accept_translation_picker(
                                    tr-src-combo.current-index,
                                    tr-tgt-combo.current-index,
                                    root.translation_picker_target,
                                );
                            }
                        }
                    }
                }
            }
        }
    }

    if root.show_color_popup : Rectangle {
        background: transparent;
        TouchArea { clicked => { root.show_color_popup = false; } }

        Rectangle {
            x: max(8px, min(root.color_popup_x, parent.width - self.width - 8px));
            y: max(8px, min(root.color_popup_y, parent.height - self.height - 8px));
            width: col-pop-grid.preferred-width + 16px;
            height: col-pop-grid.preferred-height + 16px;
            background: Theme.bg-elev;
            border-color: Theme.border-strong;
            border-width: 1px;
            border-radius: Theme.radius-md;
            drop-shadow-blur: 18px;
            drop-shadow-color: Theme.is-light ? #00000033 : #00000099;
            TouchArea { clicked => { } }

            col-pop-grid := VerticalLayout {
                padding: 8px;
                spacing: 6px;
                alignment: center;
                HorizontalLayout {
                    spacing: 6px;
                    alignment: center;
                    Rectangle {
                        width: 24px;
                        height: 24px;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: Theme.border-strong;
                        background: clear-col-ta.has-hover ? Theme.bg-hover : transparent;
                        FaGlyph {
                            glyph: "\u{f00d}";
                            weight: 900;
                            glyph-size: 11px;
                            tint: #c94c4c;
                            width: parent.width;
                            height: parent.height;
                        }
                        clear-col-ta := TouchArea {
                            clicked => {
                                if (root.color_popup_target == "accent") {
                                    root.options_accent_hex = "#5865f2";
                                    root.preview_options_accent("#5865f2");
                                } else if (root.color_popup_target == "personal") {
                                    root.set_personal_color("");
                                } else {
                                    root.set_team_color("");
                                }
                                root.show_color_popup = false;
                                if (root.color_popup_target != "accent") {
                                    root.request_save();
                                }
                            }
                        }
                    }
                    for sw[idx] in root.color_swatch_row_top : Rectangle {
                        width: 24px;
                        height: 24px;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: Theme.border-strong;
                        background: sw.swatch;
                        sw-ta := TouchArea {
                            clicked => {
                                if (root.color_popup_target == "accent") {
                                    root.options_accent_hex = sw.hex;
                                    root.preview_options_accent(sw.hex);
                                } else if (root.color_popup_target == "personal") {
                                    root.set_personal_color(sw.hex);
                                } else {
                                    root.set_team_color(sw.hex);
                                }
                                root.show_color_popup = false;
                                if (root.color_popup_target != "accent") {
                                    root.request_save();
                                }
                            }
                        }
                    }
                }
                HorizontalLayout {
                    spacing: 6px;
                    alignment: center;
                    for sw2[idx2] in root.color_swatch_row_bottom : Rectangle {
                        width: 24px;
                        height: 24px;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: Theme.border-strong;
                        background: sw2.swatch;
                        sw2-ta := TouchArea {
                            clicked => {
                                if (root.color_popup_target == "accent") {
                                    root.options_accent_hex = sw2.hex;
                                    root.preview_options_accent(sw2.hex);
                                } else if (root.color_popup_target == "personal") {
                                    root.set_personal_color(sw2.hex);
                                } else {
                                    root.set_team_color(sw2.hex);
                                }
                                root.show_color_popup = false;
                                if (root.color_popup_target != "accent") {
                                    root.request_save();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

export struct PopupItem {
    title: string,
    kind: int,
}

export struct PopupMainItem {
    title: string,
    kind: int,
}

export component SnippetPopup inherits Window {
    default-font-family: Theme.ui-font;
    default-font-weight: 400;
    no-frame: true;
    always-on-top: true;
    title: @tr("Poltergeist Snippets");
    background: transparent;

    in property <[PopupMainItem]> main-entries;
    in property <[PopupItem]> sub-entries;
    in property <bool> submenu-visible: false;
    in property <int> open-folder-row: -1;
    in property <bool> is_light: false;
    callback main_row_clicked(int);
    callback folder_hover(int);
    callback folder_leave();
    callback sub_selected(int);
    callback dismissed();

    width: root.submenu-visible ? 440px : 260px;
    height: min(460px, main-list-col.preferred-height + 16px);

    init => {
        Theme.is-light = root.is_light;
        Palette.color-scheme = root.is-light ? ColorScheme.light : ColorScheme.dark;
    }
    changed is_light => {
        Theme.is-light = root.is_light;
        Palette.color-scheme = root.is-light ? ColorScheme.light : ColorScheme.dark;
    }

    Rectangle {
        background: Theme.bg-elev;
        border-color: Theme.border-strong;
        border-width: 1px;
        border-radius: Theme.radius-md;
        drop-shadow-blur: 22px;
        drop-shadow-color: Theme.is-light ? #00000044 : #000000aa;

        fs := FocusScope {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;

            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    root.dismissed();
                    return accept;
                }
                return reject;
            }

            HorizontalLayout {
                padding: 4px;
                spacing: 0;
                ScrollView {
                    width: root.submenu-visible ? 200px : parent.width - 8px;
                    height: parent.height - 8px;
                    main-list-col := VerticalLayout {
                        spacing: 0;
                        if root.main-entries.length == 0 : Rectangle {
                            height: 28px;
                            Text {
                                text: @tr("(no snippets configured)");
                                color: Theme.text-muted;
                                font-size: 12px;
                                x: 10px;
                                vertical-alignment: center;
                                height: parent.height;
                            }
                        }
                        for mrow[idx] in root.main-entries : Rectangle {
                            height: 26px;
                            background: (m-ta.has-hover || (root.open-folder-row == idx))
                                ? Theme.bg-hover
                                : transparent;
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 8px;
                                FaGlyph {
                                    glyph: mrow.kind == 0 ? "\u{f07c}" : "\u{f328}";
                                    weight: 400;
                                    glyph-size: 11px;
                                    tint: Theme.accent;
                                    width: 14px;
                                }
                                Text {
                                    text: mrow.title;
                                    color: Theme.text;
                                    font-size: 12px;
                                    font-weight: mrow.kind == 0 ? 600 : 400;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                            }
                            m-ta := TouchArea {
                                changed has-hover => {
                                    if (mrow.kind == 0) {
                                        if (self.has-hover) {
                                            root.folder_hover(idx);
                                        }
                                    } else if (mrow.kind == 1) {
                                        if (self.has-hover) {
                                            root.folder_leave();
                                        }
                                    }
                                }
                                clicked => {
                                    if (mrow.kind == 1) {
                                        root.main_row_clicked(idx);
                                    }
                                }
                            }
                        }
                    }
                }
                if root.submenu-visible : Rectangle {
                    width: 1px;
                    height: parent.height - 8px;
                    background: Theme.border;
                }
                if root.submenu-visible : ScrollView {
                    horizontal-stretch: 1;
                    height: parent.height - 8px;
                    VerticalLayout {
                        spacing: 0;
                        if root.sub-entries.length == 0 : Rectangle {
                            height: 28px;
                            Text {
                                text: @tr("(empty folder)");
                                color: Theme.text-muted;
                                font-size: 12px;
                                x: 10px;
                                vertical-alignment: center;
                                height: parent.height;
                            }
                        }
                        for srow[sidx] in root.sub-entries : Rectangle {
                            height: 26px;
                            background: s-ta.has-hover ? Theme.bg-hover : transparent;
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 8px;
                                FaGlyph {
                                    glyph: "\u{f328}";
                                    weight: 400;
                                    glyph-size: 11px;
                                    tint: Theme.accent;
                                    width: 14px;
                                }
                                Text {
                                    text: srow.title;
                                    color: Theme.text;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                            }
                            s-ta := TouchArea {
                                clicked => { root.sub_selected(sidx); }
                            }
                        }
                    }
                }
            }
        }
    }
}
